      "html": "\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=IBM+Plex+Mono:wght@400;700&display=swap');\n\n:root {\n  --carbon-black: #1B1B1B;\n  --white-smoke: #F5F5F5;\n  --bright-lemon: #FDEE00;\n}\n\nbody {\n  background-color: var(--carbon-black);\n  color: var(--white-smoke);\n  font-family: 'IBM Plex Mono', monospace;\n  margin: 0;\n  overflow-x: clip;\n  -webkit-font-smoothing: antialiased;\n}\n\n.font-industrial { font-family: 'Oswald', sans-serif; }\n.font-mono { font-family: 'IBM Plex Mono', monospace; }\n\n.heavy-border { border: 6px solid var(--white-smoke); }\n.hairline { border: 1px solid rgba(245, 245, 245, 0.2); }\n\n.washi-tape {\n  position: absolute;\n  height: 28px;\n  background-color: var(--bright-lemon);\n  color: var(--carbon-black);\n  font-family: 'IBM Plex Mono', monospace;\n  font-weight: 800;\n  font-size: 0.7rem;\n  display: flex;\n  align-items: center;\n  padding: 0 1rem;\n  transform: rotate(-1.8deg);\n  z-index: 30;\n  pointer-events: none;\n  box-shadow: 3px 3px 0 rgba(0,0,0,0.3);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.hard-offset {\n  box-shadow: 12px 12px 0 var(--bright-lemon);\n}\n\n.text-stroke {\n  -webkit-text-stroke: 1.5px var(--white-smoke);\n  color: transparent;\n}\n\n/* Scrollbar Customization */\n::-webkit-scrollbar { width: 12px; }\n::-webkit-scrollbar-track { background: var(--carbon-black); }\n::-webkit-scrollbar-thumb { \n  background: var(--white-smoke); \n  border: 3px solid var(--carbon-black);\n}\n\n.mask-reveal {\n  clip-path: inset(0 100% 0 0);\n}\n\n.wide-sidebar {\n  width: 320px;\n  background: var(--carbon-black);\n  border-right: 12px solid var(--white-smoke);\n}\n\n.nav-link-massive {\n  font-family: 'Oswald', sans-serif;\n  font-size: 5.5rem;\n  line-height: 0.95;\n  text-transform: uppercase;\n  display: block;\n  transition: none; /* Controlled by GSAP/Hover Lift */\n}\n\n/* Layout Specifics */\n.main-viewport {\n  display: flex;\n  min-height: 100vh;\n}\n\n.content-area {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n}\n\n.hero-anchor-bottom-left {\n  position: absolute;\n  bottom: 4rem;\n  left: 4rem;\n  z-index: 20;\n}\n\n.hero-image-top-right {\n  position: absolute;\n  top: 4rem;\n  right: 4rem;\n  width: 50%;\n  height: 60%;\n  z-index: 10;\n}\n</style>\n\n<div class=\"main-viewport\" data-kid=\"2\">\n  \n  <aside class=\"wide-sidebar sticky top-0 h-screen shrink-0 flex flex-col p-10 justify-between\" data-kid=\"3\">\n    <div data-kid=\"4\">\n      <div class=\"font-industrial text-4xl text-[var(--bright-lemon)] leading-none mb-2\" data-kid=\"5\">IND_SYS</div>\n      <div class=\"font-mono text-[0.6rem] uppercase opacity-40\" data-kid=\"6\">Industrial Archive Division // v.4.0.2</div>\n    </div>\n\n    <nav class=\"flex flex-col gap-4\" data-kid=\"7\">\n      <a href=\"#\" class=\"nav-link-massive hover-lift\" data-kid=\"8\">Cargo</a>\n      <a href=\"#\" class=\"nav-link-massive hover-lift\" data-kid=\"9\">Static</a>\n      <a href=\"#\" class=\"nav-link-massive hover-lift\" data-kid=\"10\">Gear</a>\n      <a href=\"#\" class=\"nav-link-massive hover-lift\" data-kid=\"11\">Core</a>\n    </nav>\n\n    <div class=\"font-mono text-[0.65rem] space-y-4\" data-kid=\"12\">\n      <div class=\"flex flex-col gap-1\" data-kid=\"13\">\n        <span class=\"opacity-30 uppercase\" data-kid=\"14\">System_Link</span>\n        <span class=\"text-[var(--bright-lemon)]\" data-kid=\"15\">SECURE_ESTABLISHED</span>\n      </div>\n      <div class=\"flex flex-col gap-1\" data-kid=\"16\">\n        <span class=\"opacity-30 uppercase\" data-kid=\"17\">Terminal_ID</span>\n        <span data-kid=\"18\">#XP-209-DELTA</span>\n      </div>\n    </div>\n  </aside>\n\n  \n  <div class=\"content-area\" data-kid=\"19\">\n    \n    \n    <header class=\"relative h-screen bg-[var(--carbon-black)] border-b-12 border-[var(--white-smoke)] overflow-hidden\" data-kid=\"20\">\n      \n      <div class=\"absolute top-8 left-8 w-8 h-8 border-t-2 border-l-2 border-white/20 z-30\" data-kid=\"21\"></div>\n      <div class=\"absolute top-8 right-8 w-8 h-8 border-t-2 border-r-2 border-white/20 z-30\" data-kid=\"22\"></div>\n      <div class=\"absolute bottom-8 left-8 w-8 h-8 border-b-2 border-l-2 border-white/20 z-30\" data-kid=\"23\"></div>\n      <div class=\"absolute bottom-8 right-8 w-8 h-8 border-b-2 border-r-2 border-white/20 z-30\" data-kid=\"24\"></div>\n\n      <div class=\"hero-image-top-right\" data-kid=\"25\">\n        <img src=\"https://images.unsplash.com/photo-1606337321936-02d1b1a4d5ef?auto=format&w=1200&q=80&fit=crop\" alt=\"Industrial hardware Pavel Neznanov\" class=\"w-full h-full object-cover grayscale brightness-75 contrast-125 mask-reveal hero-img\" decoding=\"async\" loading=\"lazy\" data-kid=\"26\">\n        <div class=\"washi-tape -top-4 -right-8\" data-kid=\"27\">Hardware_Spec_A1</div>\n      </div>\n\n      <div class=\"hero-anchor-bottom-left max-w-6xl\" data-kid=\"28\">\n        <h1 class=\"font-industrial text-[14vw] leading-[0.8] uppercase mask-reveal hero-title\" data-kid=\"29\">\n          Industrial<br data-kid=\"30\">Override\n        </h1>\n        <div class=\"mt-8 flex gap-8 items-center mask-reveal hero-sub\" data-kid=\"31\">\n          <div class=\"bg-[var(--bright-lemon)] text-[var(--carbon-black)] px-6 py-3 font-industrial text-2xl uppercase font-bold\" data-kid=\"32\">\n            Drop_099 // Tactical\n          </div>\n          <p class=\"font-mono text-sm uppercase max-w-xs opacity-60\" data-kid=\"33\">\n            Engineered for the perimeters of the industrial void. Built for durability.\n          </p>\n        </div>\n      </div>\n    </header>\n\n    \n    <section class=\"grid grid-cols-1 md:grid-cols-12 border-b-12 border-[var(--white-smoke)] bg-[var(--carbon-black)]\" data-kid=\"34\">\n      <div class=\"md:col-span-5 p-10 border-r hairline flex flex-col justify-between\" data-kid=\"35\">\n        <div class=\"flex justify-between items-start\" data-kid=\"36\">\n          <span class=\"font-mono text-xs uppercase opacity-40 tracking-widest\" data-kid=\"37\">System_Vitals</span>\n          <div class=\"bg-[var(--bright-lemon)] text-[var(--carbon-black)] px-2 font-mono text-[0.6rem] font-bold\" data-kid=\"38\">REAL_TIME_FEED</div>\n        </div>\n        <div class=\"flex items-baseline gap-4 mt-4\" data-kid=\"39\">\n            <span class=\"font-industrial text-[8rem] leading-none counter\" data-target=\"98\" data-kid=\"40\">0</span>\n            <span class=\"font-mono text-3xl text-[var(--bright-lemon)] font-bold\" data-kid=\"41\">% EFFICIENCY</span>\n        </div>\n        <div class=\"mt-8 font-mono text-[0.6rem] flex flex-col gap-1\" data-kid=\"42\">\n          <div class=\"flex justify-between border-b border-white/10 pb-1\" data-kid=\"43\"><span data-kid=\"44\">CORE_LOAD</span> <span class=\"text-[var(--bright-lemon)]\" data-kid=\"45\">NOMINAL</span></div>\n          <div class=\"flex justify-between border-b border-white/10 pb-1\" data-kid=\"46\"><span data-kid=\"47\">THERMAL_U</span> <span class=\"text-red-500\" data-kid=\"48\">WARNING_HIGH</span></div>\n          <div class=\"flex justify-between\" data-kid=\"49\"><span data-kid=\"50\">UPTIME</span> <span data-kid=\"51\">142:22:09</span></div>\n        </div>\n      </div>\n\n      <div class=\"md:col-span-3 p-10 border-r hairline flex flex-col justify-between\" data-kid=\"52\">\n        <span class=\"font-mono text-xs uppercase opacity-40 tracking-widest\" data-kid=\"53\">Unit_Census</span>\n        <div class=\"flex items-baseline gap-2 mt-4\" data-kid=\"54\">\n            <span class=\"font-industrial text-[5rem] leading-none counter\" data-target=\"1242\" data-kid=\"55\">0</span>\n            <span class=\"font-mono text-sm opacity-40\" data-kid=\"56\">QTY</span>\n        </div>\n        <div class=\"mt-4 flex items-center gap-2\" data-kid=\"57\">\n          <div class=\"w-2 h-2 rounded-full bg-red-500 animate-pulse\" data-kid=\"58\"></div>\n          <span class=\"text-red-500 text-[0.6rem] font-bold\" data-kid=\"59\">-04%_DELTA</span>\n        </div>\n      </div>\n\n      <div class=\"md:col-span-2 p-10 border-r hairline flex flex-col justify-between bg-[var(--white-smoke)] text-[var(--carbon-black)]\" data-kid=\"60\">\n        <span class=\"font-mono text-xs uppercase opacity-40 font-bold tracking-widest\" data-kid=\"61\">Latency</span>\n        <div class=\"flex flex-col gap-1 mt-4\" data-kid=\"62\">\n            <div class=\"flex items-baseline gap-2\" data-kid=\"63\">\n              <span class=\"font-industrial text-[5rem] leading-none counter\" data-target=\"12\" data-kid=\"64\">0</span>\n              <span class=\"font-mono text-xs font-bold\" data-kid=\"65\">MS</span>\n            </div>\n            <div class=\"text-[0.5rem] font-bold border border-[var(--carbon-black)]/20 px-1 py-0.5 w-fit\" data-kid=\"66\">STATUS:OPTIMAL</div>\n        </div>\n      </div>\n\n      <div class=\"md:col-span-2 p-10 flex flex-col justify-between bg-[var(--bright-lemon)] text-[var(--carbon-black)]\" data-kid=\"67\">\n        <span class=\"font-mono text-xs uppercase font-bold tracking-widest\" data-kid=\"68\">Session</span>\n        <div class=\"font-industrial text-[5rem] leading-none\" data-kid=\"69\">04:22</div>\n        <div class=\"mt-4 font-mono text-[0.6rem] font-bold animate-pulse\" data-kid=\"70\">SYNCING...</div>\n      </div>\n    </section>\n\n    \n    <section class=\"p-16 bg-[var(--carbon-black)]\" data-kid=\"71\">\n      <div class=\"flex justify-between items-end mb-16\" data-kid=\"72\">\n        <h2 class=\"font-industrial text-9xl uppercase leading-none\" data-kid=\"73\">The Archive</h2>\n        <div class=\"font-mono text-right max-w-sm\" data-kid=\"74\">\n          <p class=\"text-xs uppercase opacity-40 mb-2\" data-kid=\"75\">Category Selection</p>\n          <div class=\"flex gap-4 font-industrial text-2xl uppercase\" data-kid=\"76\">\n            <span class=\"text-[var(--bright-lemon)] underline decoration-4 underline-offset-8\" data-kid=\"77\">All_Units</span>\n            <span class=\"opacity-40 hover:opacity-100 cursor-pointer\" data-kid=\"78\">Hardware</span>\n            <span class=\"opacity-40 hover:opacity-100 cursor-pointer\" data-kid=\"79\">Apparel</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-16 items-start masonry-grid\" data-kid=\"80\">\n        \n        \n        <div class=\"space-y-16\" data-kid=\"81\">\n          \n          <div class=\"product-card group relative bg-[var(--carbon-black)] border-4 border-[var(--white-smoke)] overflow-hidden hard-offset\" data-kid=\"82\">\n            <div class=\"washi-tape top-4 left-4\" data-kid=\"83\">New_Drop_Detected</div>\n            <div class=\"aspect-[3/4] overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700\" data-kid=\"84\">\n              <img src=\"https://images.unsplash.com/photo-1637989621168-994b37a3352b?auto=format&w=800&q=80&fit=crop\" alt=\"Tactical Jacket mehrab zahedbeigi\" class=\"w-full h-full object-cover\" data-kid=\"85\">\n            </div>\n            <div class=\"p-8 bg-[var(--carbon-black)] border-t-4 border-[var(--white-smoke)]\" data-kid=\"86\">\n              <h3 class=\"font-industrial text-5xl uppercase leading-none mb-4\" data-kid=\"87\">Vortex Shell</h3>\n              <div class=\"flex justify-between items-center\" data-kid=\"88\">\n                <span class=\"font-industrial text-4xl\" data-kid=\"89\">$485.00</span>\n                <button class=\"bg-[var(--bright-lemon)] text-[var(--carbon-black)] px-6 py-2 font-industrial text-lg uppercase font-bold\" data-kid=\"90\">Acquire</button>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"product-card group relative bg-[var(--carbon-black)] border-4 border-[var(--white-smoke)] p-8\" data-kid=\"91\">\n            <h3 class=\"font-industrial text-3xl uppercase mb-4\" data-kid=\"92\">Tactical_Briefing</h3>\n            <p class=\"font-mono text-sm opacity-60 leading-relaxed mb-8\" data-kid=\"93\">\n              All gear is tested in extreme environments. Guaranteed functionality under heavy load.\n            </p>\n            <div class=\"h-1 bg-[var(--white-smoke)]/20 w-full mb-8\" data-kid=\"94\"></div>\n            <button class=\"w-full border-2 border-[var(--white-smoke)] py-4 font-industrial text-2xl uppercase hover:bg-[var(--white-smoke)] hover:text-[var(--carbon-black)]\" data-kid=\"95\">View Manifest</button>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-16 pt-24\" data-kid=\"96\">\n          <div class=\"product-card group relative bg-[var(--carbon-black)] border-4 border-[var(--white-smoke)] p-6\" data-kid=\"97\">\n            <div class=\"aspect-square overflow-hidden mb-6 grayscale group-hover:grayscale-0 transition-all duration-700\" data-kid=\"98\">\n              <img src=\"https://images.unsplash.com/photo-1600267187858-9dafb868f490?auto=format&w=800&q=80&fit=crop\" alt=\"Tactical pants Karsten Winegeart\" class=\"w-full h-full object-cover\" data-kid=\"99\">\n            </div>\n            <h3 class=\"font-industrial text-4xl uppercase leading-none mb-2\" data-kid=\"100\">Omni Cargo</h3>\n            <p class=\"font-mono text-[0.6rem] opacity-40 uppercase tracking-widest mb-6\" data-kid=\"101\">Modular_Pocket_System // Tech_Grip</p>\n            <div class=\"flex justify-between items-end\" data-kid=\"102\">\n              <span class=\"font-industrial text-4xl text-[var(--bright-lemon)]\" data-kid=\"103\">$220.00</span>\n              <div class=\"bg-[var(--bright-lemon)]/20 text-[var(--bright-lemon)] px-3 py-1 font-mono text-[0.6rem] font-bold\" data-kid=\"104\">LAST_UNITS</div>\n            </div>\n          </div>\n\n          <div class=\"product-card group relative bg-[var(--carbon-black)] border-4 border-[var(--white-smoke)] p-6 hard-offset\" data-kid=\"105\">\n            <div class=\"washi-tape -top-2 -right-4 rotate-3\" data-kid=\"106\">Clearance_Required</div>\n            <div class=\"aspect-[3/5] overflow-hidden mb-8 grayscale group-hover:grayscale-0 transition-all duration-700\" data-kid=\"107\">\n              <img src=\"https://images.unsplash.com/photo-1656785851126-b2e4d927a48b?auto=format&w=800&q=80&fit=crop\" alt=\"Tactical boots Erfan Sattarvand\" class=\"w-full h-full object-cover\" data-kid=\"108\">\n            </div>\n            <h3 class=\"font-industrial text-5xl uppercase leading-none mb-4\" data-kid=\"109\">Titan Boot</h3>\n            <div class=\"flex gap-2 mb-8\" data-kid=\"110\">\n                <span class=\"bg-[var(--white-smoke)]/10 text-xs px-2 py-1 font-mono uppercase\" data-kid=\"111\">Vibram_Sole</span>\n                <span class=\"bg-[var(--white-smoke)]/10 text-xs px-2 py-1 font-mono uppercase\" data-kid=\"112\">Steel_Toe</span>\n            </div>\n            <button class=\"w-full bg-[var(--bright-lemon)] text-[var(--carbon-black)] py-5 font-industrial text-3xl uppercase font-bold\" data-kid=\"113\">Secure_Unit</button>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-16 pt-12\" data-kid=\"114\">\n          <div class=\"product-card group relative bg-[var(--carbon-black)] border-4 border-[var(--white-smoke)] p-6\" data-kid=\"115\">\n            <div class=\"aspect-[4/5] overflow-hidden mb-8 grayscale group-hover:grayscale-0 transition-all duration-700\" data-kid=\"116\">\n              <img src=\"https://images.pexels.com/photos/15422351/pexels-photo-15422351.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Police officer gear Dextar Vision\" class=\"w-full h-full object-cover\" data-kid=\"117\">\n            </div>\n            <h3 class=\"font-industrial text-4xl uppercase leading-none mb-4\" data-kid=\"118\">Enforcer Pack</h3>\n            <p class=\"font-mono text-xs opacity-50 mb-8 leading-relaxed\" data-kid=\"119\">\n              Complete equipment deployment system for the most demanding urban environments.\n            </p>\n            <div class=\"flex justify-between items-center\" data-kid=\"120\">\n              <span class=\"font-industrial text-4xl\" data-kid=\"121\">$750.00</span>\n              <div class=\"flex gap-1\" data-kid=\"122\">\n                <div class=\"w-4 h-4 bg-[var(--white-smoke)]\" data-kid=\"123\"></div>\n                <div class=\"w-4 h-4 bg-[var(--bright-lemon)]\" data-kid=\"124\"></div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"product-card group relative bg-[var(--bright-lemon)] border-4 border-[var(--carbon-black)] p-8 text-[var(--carbon-black)]\" data-kid=\"125\">\n            <h3 class=\"font-industrial text-3xl md:text-4xl uppercase mb-4\" data-kid=\"126\">Support_Uplink</h3>\n            <p class=\"font-mono text-xs md:text-sm font-bold leading-relaxed mb-8\" data-kid=\"127\">\n              Technical assistance available 24/7 via secure industrial terminal.\n            </p>\n            <button class=\"w-full bg-[var(--carbon-black)] text-[var(--bright-lemon)] py-3 font-industrial text-xl uppercase\" data-kid=\"128\">Open_Comms</button>\n          </div>\n        </div>\n\n      </div>\n    </section>\n\n    \n    <footer class=\"bg-[var(--carbon-black)] border-t-24 border-[var(--bright-lemon)] pt-24 px-16 pb-12 relative overflow-hidden\" data-kid=\"129\">\n      <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none flex items-center justify-center\" data-kid=\"130\">\n        <h1 class=\"font-industrial text-[40vw] text-white whitespace-nowrap select-none\" data-kid=\"131\">IND_SYS</h1>\n      </div>\n\n      <div class=\"relative z-10\" data-kid=\"132\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-4 gap-20 mb-32\" data-kid=\"133\">\n          <div class=\"lg:col-span-2\" data-kid=\"134\">\n            <h2 class=\"font-industrial text-9xl uppercase leading-none mb-12\" data-kid=\"135\">Manifest</h2>\n            <div class=\"grid grid-cols-2 gap-8 font-mono text-sm max-w-xl\" data-kid=\"136\">\n              <div class=\"space-y-4\" data-kid=\"137\">\n                <div class=\"flex flex-col gap-1\" data-kid=\"138\">\n                  <span class=\"opacity-40 uppercase\" data-kid=\"139\">Registration</span>\n                  <span data-kid=\"140\">#IND-2024-99X</span>\n                </div>\n                <div class=\"flex flex-col gap-1\" data-kid=\"141\">\n                  <span class=\"opacity-40 uppercase\" data-kid=\"142\">Entity</span>\n                  <span data-kid=\"143\">INDUSTRIAL_MONOCHROME_GRP</span>\n                </div>\n              </div>\n              <div class=\"space-y-4\" data-kid=\"144\">\n                <div class=\"flex flex-col gap-1\" data-kid=\"145\">\n                  <span class=\"opacity-40 uppercase\" data-kid=\"146\">Location</span>\n                  <span data-kid=\"147\">WAREHOUSE_DISTRICT_4</span>\n                </div>\n                <div class=\"flex flex-col gap-1\" data-kid=\"148\">\n                  <span class=\"opacity-40 uppercase\" data-kid=\"149\">Protocol</span>\n                  <span data-kid=\"150\">ZERO_RETURN_POLICY</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div data-kid=\"151\">\n            <h4 class=\"font-industrial text-3xl uppercase mb-8 border-b-4 border-[var(--white-smoke)] pb-2\" data-kid=\"152\">Logistics</h4>\n            <ul class=\"font-mono space-y-4 uppercase text-sm\" data-kid=\"153\">\n              <li data-kid=\"154\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)] flex justify-between\" data-kid=\"155\">Shipping_Units <span data-kid=\"156\">>></span></a></li>\n              <li data-kid=\"157\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)] flex justify-between\" data-kid=\"158\">Order_Vault <span data-kid=\"159\">>></span></a></li>\n              <li data-kid=\"160\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)] flex justify-between\" data-kid=\"161\">Carrier_ID <span data-kid=\"162\">>></span></a></li>\n              <li data-kid=\"163\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)] flex justify-between\" data-kid=\"164\">Supply_Node <span data-kid=\"165\">>></span></a></li>\n            </ul>\n          </div>\n\n          <div data-kid=\"166\">\n            <h4 class=\"font-industrial text-3xl uppercase mb-8 border-b-4 border-[var(--white-smoke)] pb-2\" data-kid=\"167\">Protocols</h4>\n            <ul class=\"font-mono space-y-4 uppercase text-sm\" data-kid=\"168\">\n              <li data-kid=\"169\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)]\" data-kid=\"170\">Encryption_Standard</a></li>\n              <li data-kid=\"171\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)]\" data-kid=\"172\">System_Integrity</a></li>\n              <li data-kid=\"173\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)]\" data-kid=\"174\">Privacy_Manifest</a></li>\n              <li data-kid=\"175\"><a href=\"#\" class=\"hover:text-[var(--bright-lemon)]\" data-kid=\"176\">Hardware_License</a></li>\n            </ul>\n          </div>\n        </div>\n\n        <div class=\"flex flex-col md:flex-row justify-between items-end gap-8 pt-12 border-t border-[var(--white-smoke)]/10 font-mono text-[0.65rem] uppercase tracking-wider\" data-kid=\"177\">\n          <div class=\"space-y-1\" data-kid=\"178\">\n            <p class=\"font-bold\" data-kid=\"179\">&copy; 2024 INDUSTRIAL_MONOCHROME // AUTHENTICATED_TERMINAL_SESSION</p>\n            <p class=\"opacity-30\" data-kid=\"180\">ENCRYPTION: AES-256 // PROTOCOL: TR7-X</p>\n          </div>\n          <div class=\"flex gap-12\" data-kid=\"181\">\n            <div class=\"flex flex-col items-end\" data-kid=\"182\">\n              <span class=\"opacity-30\" data-kid=\"183\">Coordinates</span>\n              <span data-kid=\"184\">51.5074° N, 0.1278° W</span>\n            </div>\n            <div class=\"flex flex-col items-end\" data-kid=\"185\">\n              <span class=\"opacity-30\" data-kid=\"186\">Server_Time</span>\n              <span class=\"text-[var(--bright-lemon)]\" id=\"server-time\" data-kid=\"187\">23:59:59</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </footer>\n\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"188\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"189\"></script>\n<script type=\"module\" data-kid=\"190\">\n  import { animate } from 'https://esm.sh/animejs@4';\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // #gsap-mask-wipe Entrance\n  const heroReveal = gsap.timeline();\n  heroReveal\n    .to(\".hero-img\", { clipPath: \"inset(0 0% 0 0)\", duration: 1.5, ease: \"power4.inOut\" })\n    .to(\".hero-title\", { clipPath: \"inset(0 0% 0 0)\", duration: 1.2, ease: \"power3.inOut\" }, \"-=1.2\")\n    .to(\".hero-sub\", { clipPath: \"inset(0 0% 0 0)\", duration: 1, ease: \"power2.out\" }, \"-=0.8\");\n\n  // #anime-counter-integer\n  const counterElements = document.querySelectorAll('.counter');\n  counterElements.forEach(el => {\n    const targetValue = parseInt(el.getAttribute('data-target'));\n    const state = { value: 0 };\n    \n    ScrollTrigger.create({\n      trigger: el,\n      start: \"top 90%\",\n      onEnter: () => {\n        animate(state, {\n          value: targetValue,\n          duration: 2000,\n          modifier: (v) => Math.round(v),\n          ease: \"outQuad\",\n          onUpdate: () => {\n            el.textContent = state.value;\n          }\n        });\n      }\n    });\n  });\n\n  // #gsap-scroll-batch Card Reveals\n  ScrollTrigger.batch(\".product-card\", {\n    start: \"top 85%\",\n    onEnter: batch => gsap.fromTo(batch, \n      { autoAlpha: 0, y: 50 },\n      { autoAlpha: 1, y: 0, stagger: 0.1, duration: 0.8, ease: \"power2.out\", overwrite: true }\n    ),\n  });\n\n  // #motion-hover-lift (using GSAP for more control and to avoid transitions clash)\n  const hoverLinks = document.querySelectorAll('.hover-lift');\n  hoverLinks.forEach(link => {\n    link.addEventListener('mouseenter', () => {\n      gsap.to(link, { \n        y: -10, \n        x: 10,\n        color: '#FDEE00', \n        duration: 0.4, \n        ease: \"power2.out\" \n      });\n    });\n    link.addEventListener('mouseleave', () => {\n      gsap.to(link, { \n        y: 0, \n        x: 0,\n        color: '#F5F5F5', \n        duration: 0.4, \n        ease: \"power2.out\" \n      });\n    });\n  });\n\n  // Server Time Update\n  function updateTime() {\n    const now = new Date();\n    const timeString = now.toTimeString().split(' ')[0];\n    const timeEl = document.getElementById('server-time');\n    if(timeEl) timeEl.textContent = timeString;\n  }\n  setInterval(updateTime, 1000);\n  updateTime();\n\n</script>\n",
      "comments": [],
      "created": "2026-07-10T04:18:33.140791+00:00",
