2 border-white font-syncopate text-xs font-black uppercase tracking-widest hover:bg-[var(--neon-fuchsia)] hover:text-[var(--ink-black)] hover:border-[var(--neon-fuchsia)] transition-all cursor-pointer\" data-kid=\"91\">\n            SYNC_TO_CART\n          </button>\n        </div>\n\n        \n        <div class=\"product-card-tilted group fade-up-target card-rotate-alt -mt-8\" data-kid=\"92\">\n          <div class=\"relative overflow-hidden aspect-square border-2 border-white mb-6 bg-white/5\" data-kid=\"93\">\n            <img src=\"https://images.unsplash.com/photo-1576152017125-6980b89222a6?auto=format&w=800&q=80\" alt=\"TECH_SHIFT Sneaker\" class=\"w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:hue-rotate-15 hover-distort\" decoding=\"async\" loading=\"lazy\" data-kid=\"94\">\n            <div class=\"absolute top-4 left-4 border-2 border-[var(--cyan-glow)] text-[var(--cyan-glow)] px-3 py-1 font-syncopate text-[9px] font-black uppercase\" data-kid=\"95\">LIMITED</div>\n          </div>\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"96\">\n            <h3 class=\"font-syncopate text-xl font-bold uppercase leading-none\" data-kid=\"97\">TECH_SHIFT_09</h3>\n            <span class=\"font-fira text-[var(--cyan-glow)] font-bold text-lg\" data-kid=\"98\">$620</span>\n          </div>\n          <p class=\"font-fira text-xs opacity-60 uppercase mb-8 leading-relaxed\" data-kid=\"99\">Impact_reduction shell // stealth_fabric // bio-sync tread</p>\n          <button class=\"w-full py-4 border-2 border-white font-syncopate text-xs font-black uppercase tracking-widest hover:bg-white hover:text-[var(--ink-black)] transition-all cursor-pointer\" data-kid=\"100\">\n            SYNC_TO_CART\n          </button>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"mt-40 border-t border-white/10 pt-40\" data-kid=\"101\">\n    <div class=\"max-w-4xl mx-auto border-2 border-[var(--cyan-glow)] bg-[var(--ink-black)]/90 overflow-hidden shadow-[0_0_50px_rgba(15,255,255,0.1)]\" data-kid=\"102\">\n      \n      \n      <div class=\"bg-[var(--cyan-glow)] text-[var(--ink-black)] px-6 py-3 flex justify-between items-center\" data-kid=\"103\">\n        <div class=\"flex gap-2\" data-kid=\"104\">\n          <div class=\"w-3 h-3 rounded-full border border-[var(--ink-black)] bg-[#FF5F56]\" data-kid=\"105\"></div>\n          <div class=\"w-3 h-3 rounded-full border border-[var(--ink-black)] bg-[#FFBD2E]\" data-kid=\"106\"></div>\n          <div class=\"w-3 h-3 rounded-full border border-[var(--ink-black)] bg-[#27C93F]\" data-kid=\"107\"></div>\n        </div>\n        <div class=\"font-syncopate text-[10px] font-black uppercase tracking-[0.3em]\" data-kid=\"108\">PULSE_TERMINAL_V4.0</div>\n        <div class=\"w-12\" data-kid=\"109\"></div>\n      </div>\n      \n      \n      <div class=\"p-12 font-fira text-lg space-y-8 text-[var(--cyan-glow)]\" data-kid=\"110\">\n        <div class=\"terminal-line\" data-kid=\"111\">\n          <span class=\"text-[var(--neon-fuchsia)] font-bold\" data-kid=\"112\">$</span>\n          <span class=\"typewriter-text\" data-text=\"INITIALIZING_COMM_LINK_SEQUENCE...\" data-kid=\"113\"></span>\n        </div>\n        \n        <div class=\"terminal-output opacity-0 transition-opacity duration-500\" data-kid=\"114\">\n          <div class=\"flex gap-4 mb-4\" data-kid=\"115\">\n            <span class=\"text-[var(--neon-fuchsia)] font-bold\" data-kid=\"116\">$</span>\n            <span class=\"uppercase\" data-kid=\"117\">DETECTION: USER_LEVEL_PREMIUM</span>\n          </div>\n          <div class=\"flex gap-4 mb-10\" data-kid=\"118\">\n            <span class=\"text-[var(--neon-fuchsia)] font-bold\" data-kid=\"119\">$</span>\n            <span class=\"uppercase\" data-kid=\"120\">ENTER_UPLINK_EMAIL_</span>\n            <span class=\"inline-block w-2.5 h-6 bg-[var(--cyan-glow)] cursor-blink align-middle\" data-kid=\"121\"></span>\n          </div>\n          \n          <div class=\"border-2 border-dashed border-[var(--neon-fuchsia)]/40 p-8 flex gap-6\" data-kid=\"122\">\n            <input type=\"text\" placeholder=\"TYPE_EMAIL_FOR_NOTIFICATIONS\" class=\"bg-transparent border-b border-[var(--neon-fuchsia)]/60 flex-1 outline-hidden text-[var(--cyan-glow)] font-fira uppercase placeholder:text-white/20\" data-kid=\"123\">\n            <button class=\"bg-[var(--neon-fuchsia)] text-[var(--ink-black)] px-10 py-3 font-syncopate text-[10px] font-black uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all\" data-kid=\"124\">\n              EXECUTE\n            </button>\n          </div>\n        </div>\n\n        <div class=\"pt-12 grid grid-cols-1 md:grid-cols-2 gap-12 text-xs uppercase opacity-40\" data-kid=\"125\">\n          <div data-kid=\"126\">\n            <div class=\"text-[var(--neon-fuchsia)] mb-4 font-bold tracking-widest font-syncopate\" data-kid=\"127\">// NAVIGATION_LINKS</div>\n            <ul class=\"space-y-3 font-bold\" data-kid=\"128\">\n              <li data-kid=\"129\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"130\">>> TERMINAL_HOME</a></li>\n              <li data-kid=\"131\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"132\">>> ACTIVE_DROPS</a></li>\n              <li data-kid=\"133\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"134\">>> ARCHIVE_DATACENTER</a></li>\n            </ul>\n          </div>\n          <div data-kid=\"135\">\n            <div class=\"text-[var(--neon-fuchsia)] mb-4 font-bold tracking-widest font-syncopate\" data-kid=\"136\">// LEGAL_ENCRYPTION</div>\n            <ul class=\"space-y-3 font-bold\" data-kid=\"137\">\n              <li data-kid=\"138\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"139\">>> PRIVACY_ENCRYPT</a></li>\n              <li data-kid=\"140\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"141\">>> TERMS_OF_ENGAGEMENT</a></li>\n              <li data-kid=\"142\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"143\">>> REFUND_POLICY_NA</a></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n    \n    \n    <div class=\"mt-40 flex flex-col md:flex-row justify-between items-center gap-10 font-syncopate text-xs font-black opacity-30 tracking-[0.4em] uppercase\" data-kid=\"144\">\n      <div data-kid=\"145\">© 2024 PULSE.SYS // DECENTRALIZED_AESTHETIC_GROUP</div>\n      <div class=\"flex gap-12\" data-kid=\"146\">\n        <span data-kid=\"147\">LATENCY: 12MS</span>\n        <span data-kid=\"148\">UPTIME: 99.99%</span>\n        <span data-kid=\"149\">REGION: TOKYO_NORTH</span>\n      </div>\n    </div>\n  </footer>\n\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"150\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"151\"></script>\n<script type=\"module\" data-kid=\"152\">\n  import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  // Register GSAP plugins\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Smooth Scroll\n  const lenis = new Lenis();\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Custom Cursor\n  const cursor = document.getElementById('custom-cursor');\n  const follower = document.querySelector('.cursor-follower');\n  \n  document.addEventListener('mousemove', (e) => {\n    gsap.to(cursor, {\n      x: e.clientX - 12,\n      y: e.clientY - 12,\n      duration: 0.1,\n      ease: \"power2.out\"\n    });\n    gsap.to(follower, {\n      x: e.clientX - 4,\n      y: e.clientY - 4,\n      duration: 0.3,\n      ease: \"power3.out\"\n    });\n  });\n\n  // Scale cursor on links\n  document.querySelectorAll('a, button').forEach(el => {\n    el.addEventListener('mouseenter', () => {\n      gsap.to(cursor, { scale: 2, duration: 0.3 });\n    });\n    el.addEventListener('mouseleave', () => {\n      gsap.to(cursor, { scale: 1, duration: 0.3 });\n    });\n  });\n\n  // #anime-text-scramble\n  const scrambleElements = document.querySelectorAll('.scramble-target');\n  const chars = \"!<>-_\\\\/[]{}—=+*^?#________\";\n  \n  const runScramble = (el) => {\n    const final = el.getAttribute('data-text');\n    let iteration = 0;\n    const interval = setInterval(() => {\n      el.innerText = final.split(\"\")\n        .map((char, index) => {\n          if (index < iteration) return final[index];\n          return chars[Math.floor(Math.random() * chars.length)];\n        })\n        .join(\"\");\n      \n      if (iteration >= final.length) clearInterval(interval);\n      iteration += 1 / 2;\n    }, 40);\n  };\n\n  const scrambleObserver = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        runScramble(entry.target);\n        scrambleObserver.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.5 });\n  scrambleElements.forEach(el => scrambleObserver.observe(el));\n\n  // #gsap-fade-up\n  gsap.from(\".bento-cell\", {\n    y: 50,\n    autoAlpha: 0,\n    duration: 1,\n    stagger: 0.1,\n    ease: \"expo.out\",\n    scrollTrigger: {\n      trigger: \".bento-grid\",\n      start: \"top 80%\"\n    }\n  });\n\n  gsap.from(\".fade-up-target\", {\n    y: 80,\n    autoAlpha: 0,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power4.out\",\n    scrollTrigger: {\n      trigger: \".tilted-grid-wrapper\",\n      start: \"top 70%\"\n    }\n  });\n\n  // #anime-marquee-diagonal\n  animate(\".ticker-track\", { \n    x: [\"0%\", \"-50%\"] \n  }, { \n    duration: 15, \n    repeat: Infinity, \n    ease: \"linear\" \n  });\n\n  // #anime-text-typewriter for Terminal\n  const runTerminal = async () => {\n    const typewriter = document.querySelector('.typewriter-text');\n    const output = document.querySelector('.terminal-output');\n    const text = typewriter.getAttribute('data-text');\n    \n    typewriter.innerText = \"\";\n    for(let i=0; i < text.length; i++) {\n      typewriter.innerText += text[i];\n      await new Promise(r => setTimeout(r, 40));\n    }\n    \n    gsap.to(output, { opacity: 1, y: -10, duration: 0.8, ease: \"power2.out\" });\n  };\n\n  const terminalTrigger = new IntersectionObserver((entries) => {\n    if(entries[0].isIntersecting) {\n      runTerminal();\n      terminalTrigger.disconnect();\n    }\n  }, { threshold: 0.5 });\n  terminalTrigger.observe(document.querySelector('.terminal-line'));\n\n  // #anime-hover-icon-wiggle\n  const navIcon = document.querySelector('.nav-icon-wiggle');\n  navIcon.parentElement.addEventListener('pointerenter', () => {\n    animate(navIcon, { \n      rotate: [0, -15, 10, -5, 0] \n    }, { \n      duration: 0.5, \n      ease: \"easeOut\" \n    });\n  });\n\n  // HUD Clock\n  setInterval(() => {\n    const now = new Date();\n    document.getElementById('sys-time').innerText = now.toTimeString().split(' ')[0];\n  }, 1000);\n\n</script>\n",
