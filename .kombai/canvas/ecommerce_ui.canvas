      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"1\">\n<style data-kid=\"2\">\n@import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;700&display=swap');\n\n:root {\n  --ink-black: #010B13;\n  --snow-white: #F7F7F7;\n  --neon-chartreuse: #E3FF00;\n}\n\nbody {\n  background-color: var(--ink-black);\n  color: var(--snow-white);\n  font-family: 'Space Grotesk', sans-serif;\n  overflow-x: clip;\n}\n\n.font-anton { font-family: 'Anton', sans-serif; }\n.font-space { font-family: 'Space Grotesk', sans-serif; }\n\n.brutalist-border {\n  border: 5px solid var(--snow-white);\n}\n\n.hard-offset {\n  box-shadow: 8px 8px 0px var(--neon-chartreuse);\n}\n\n.text-stroke {\n  -webkit-text-stroke: 2px var(--snow-white);\n  color: transparent;\n}\n\n.marquee-track {\n  display: flex;\n  white-space: nowrap;\n}\n\n.glitch-hover:hover {\n  filter: url(#glitch);\n}\n\n/* Custom Cursor */\n#custom-cursor {\n  position: fixed;\n  width: 20px;\n  height: 20px;\n  background: var(--neon-chartreuse);\n  pointer-events: none;\n  z-index: 9999;\n  mix-blend-difference: difference;\n}\n\n/* Diagonal Marquee */\n.diagonal-bg {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 200%;\n  height: 200%;\n  transform: rotate(-15deg) translateY(-25%);\n  z-index: -1;\n  opacity: 0.03;\n  pointer-events: none;\n}\n</style>\n\n\n<div id=\"custom-cursor\" data-kid=\"3\"></div>\n\n\n<div class=\"diagonal-bg overflow-hidden flex flex-col gap-8\" data-kid=\"4\">\n  <div class=\"flex whitespace-nowrap animate-marquee-fast font-anton text-[20vw] leading-none text-white\" data-kid=\"5\">VOID SYSTEM VOID SYSTEM VOID SYSTEM</div>\n  <div class=\"flex whitespace-nowrap animate-marquee-reverse-fast font-anton text-[20vw] leading-none text-white\" data-kid=\"6\">DROP DETECTED DROP DETECTED DROP DETECTED</div>\n</div>\n\n\n<div id=\"smooth-wrapper\" data-kid=\"7\">\n  <div id=\"smooth-content\" data-kid=\"8\">\n\n    \n    <nav class=\"sticky top-0 z-50 bg-[var(--ink-black)] p-4 md:p-6\" data-kid=\"9\">\n      <div class=\"flex items-center gap-4 md:gap-8 bg-[var(--ink-black)]\" data-kid=\"10\">\n        <a href=\"#\" class=\"px-8 py-3 bg-[var(--neon-chartreuse)] text-[var(--ink-black)] font-anton text-3xl md:text-4xl uppercase tracking-tighter hover:scale-95 transition-transform shrink-0 border-[5px] border-[var(--snow-white)] shadow-[6px_6px_0_var(--snow-white)]\" data-kid=\"11\">\n          HYPE.SYS\n        </a>\n        \n        <div class=\"flex-1 relative flex items-center h-full brutalist-border p-3 bg-white/5\" data-kid=\"12\">\n          <span class=\"absolute left-4 text-[var(--neon-chartreuse)] font-mono text-2xl animate-pulse\" data-kid=\"13\">></span>\n          <input type=\"text\" placeholder=\"QUERY_THE_VOID...\" class=\"w-full bg-transparent border-none outline-hidden pl-12 pr-4 text-xl md:text-3xl font-bold placeholder-[var(--snow-white)]/30 uppercase font-space\" data-kid=\"14\">\n        </div>\n\n        <div class=\"hidden lg:flex items-center gap-6 font-mono text-xs uppercase opacity-60\" data-kid=\"15\">\n          <div class=\"flex flex-col\" data-kid=\"16\">\n            <span data-kid=\"17\">UPLINK_STATUS</span>\n            <span class=\"text-[var(--neon-chartreuse)]\" data-kid=\"18\">SECURE_ESTABLISHED</span>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"19\">\n            <span data-kid=\"20\">LATENCY</span>\n            <span data-kid=\"21\">12MS_ACTIVE</span>\n          </div>\n        </div>\n\n        <button class=\"relative w-14 h-14 bg-[var(--neon-chartreuse)] text-[var(--ink-black)] flex items-center justify-center font-bold text-2xl border-2 border-[var(--ink-black)] shadow-[4px_4px_0_var(--snow-white)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all\" data-kid=\"22\">\n          04\n        </button>\n      </div>\n    </nav>\n\n    \n    <header class=\"relative min-h-[90vh] flex flex-col items-center justify-center pt-10 px-4 overflow-hidden\" data-kid=\"23\">\n      \n      <div class=\"absolute inset-0 flex items-center justify-center select-none pointer-events-none\" data-kid=\"24\">\n        <h1 class=\"hero-main-text font-anton text-[18vw] md:text-[22vw] leading-none uppercase tracking-tighter opacity-100 whitespace-nowrap text-[var(--snow-white)]\" data-kid=\"25\">\n          SYSTEM_OVERRIDE\n        </h1>\n      </div>\n\n      \n      <div class=\"relative z-10 w-full max-w-5xl transform -rotate-1 hover:rotate-0 transition-all duration-1000 group\" data-kid=\"26\">\n        \n        <div class=\"relative overflow-hidden\" data-kid=\"27\">\n          <img src=\"https://images.unsplash.com/photo-1573717500278-b79410ddef66?auto=format&w=1400&q=90&fit=crop\" alt=\"V0ID-WALK Sneaker\" class=\"w-full h-auto mix-blend-screen grayscale brightness-125 contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"28\">\n        </div>\n        \n        \n        <div class=\"absolute top-1/4 -left-10 md:-left-20 bg-[var(--neon-chartreuse)] text-[var(--ink-black)] p-4 brutalist-border shadow-[8px_8px_0_var(--ink-black)] animate-bounce font-anton text-2xl rotate-12\" data-kid=\"29\">\n          NEW_DROP\n        </div>\n        <div class=\"absolute bottom-1/4 -right-10 md:-right-20 bg-[var(--snow-white)] text-[var(--ink-black)] p-3 brutalist-border shadow-[8px_8px_0_var(--neon-chartreuse)] font-mono text-sm -rotate-6\" data-kid=\"30\">\n          V0ID_WALK_X1\n        </div>\n      </div>\n\n      \n      <div class=\"relative z-20 w-full max-w-screen-2xl mt-auto py-12 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"31\">\n        <div class=\"brutalist-border p-8 bg-[var(--ink-black)] hard-offset self-start flex flex-col items-start min-w-[320px]\" data-kid=\"32\">\n          <div class=\"text-sm font-bold font-mono uppercase mb-3 text-[var(--neon-chartreuse)]\" data-kid=\"33\">ESTIMATED_DROP_TIME_MANIFEST</div>\n          <div class=\"font-anton text-7xl md:text-9xl flex gap-4 text-[var(--neon-chartreuse)] scramble-target\" data-text=\"02:14:55:08\" data-kid=\"34\">\n            02:14:55:08\n          </div>\n        </div>\n        \n        <div class=\"max-w-2xl text-center md:text-right font-space space-y-6\" data-kid=\"35\">\n          <p class=\"text-3xl md:text-5xl font-anton uppercase leading-none text-[var(--neon-chartreuse)]\" data-kid=\"36\">\n            \"THE PERIPHERY OF THE VOID IS NO LONGER SILENT.\"\n          </p>\n          <p class=\"text-xl font-bold uppercase opacity-60\" data-kid=\"37\">\n            LOC_DETECTED: 51.5074° N, 0.1278° W // SECURITY_LEVEL_CRITICAL\n          </p>\n          <div class=\"flex justify-end gap-4\" data-kid=\"38\">\n            <button class=\"px-8 py-3 bg-[var(--snow-white)] text-[var(--ink-black)] font-anton text-xl uppercase brutalist-border hover:bg-[var(--neon-chartreuse)] transition-colors\" data-kid=\"39\">\n              SYNC_DROP\n            </button>\n          </div>\n        </div>\n      </div>\n    </header>\n\n    \n    <section class=\"py-24 bg-[var(--ink-black)] relative border-y-4 border-[var(--snow-white)]\" data-kid=\"40\">\n      <div class=\"marquee-wrapper space-y-2\" data-kid=\"41\">\n        \n        <div class=\"flex whitespace-nowrap overflow-hidden py-4 border-b-2 border-[var(--snow-white)]/20 marquee-row-1\" data-kid=\"42\">\n          <div class=\"flex items-center space-x-20 px-10 animate-marquee\" data-kid=\"43\">\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"44\">FOOTWEAR</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"45\">OUTERWEAR</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"46\">HARDWARE</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"47\">ACCESSORIES</span>\n          </div>\n          <div class=\"flex items-center space-x-20 px-10 animate-marquee\" data-kid=\"48\">\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"49\">FOOTWEAR</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"50\">OUTERWEAR</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"51\">HARDWARE</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-stroke hover:text-[var(--neon-chartreuse)] hover:[-webkit-text-stroke:0] cursor-pointer transition-all\" data-kid=\"52\">ACCESSORIES</span>\n          </div>\n        </div>\n        \n        <div class=\"flex whitespace-nowrap overflow-hidden py-4 marquee-row-2\" data-kid=\"53\">\n          <div class=\"flex items-center space-x-20 px-10 animate-marquee-reverse\" data-kid=\"54\">\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"55\">V0ID_CORE</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"56\">STREET_HYPE</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"57\">CYBER_DRIP</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"58\">TECH_SPEC</span>\n          </div>\n          <div class=\"flex items-center space-x-20 px-10 animate-marquee-reverse\" data-kid=\"59\">\n             <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"60\">V0ID_CORE</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"61\">STREET_HYPE</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"62\">CYBER_DRIP</span>\n            <span class=\"font-anton text-8xl md:text-[10rem] uppercase text-[var(--neon-chartreuse)] hover:text-[var(--snow-white)] cursor-pointer transition-all\" data-kid=\"63\">TECH_SPEC</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 px-4 md:px-8 relative bg-white/5 overflow-hidden\" data-kid=\"64\">\n      \n      <div class=\"absolute inset-0 opacity-15 pointer-events-none mix-blend-overlay\" style=\"background-image: url('https://images.unsplash.com/photo-1708894462826-ba3fa93b41b7?auto=format&w=1200&q=50'); background-size: cover;\" data-kid=\"65\"></div>\n      \n      <div class=\"max-w-[1600px] mx-auto relative z-10\" data-kid=\"66\">\n        <div class=\"mb-24 flex flex-col md:flex-row justify-between items-baseline gap-6\" data-kid=\"67\">\n          <h2 class=\"font-anton text-8xl md:text-[12rem] leading-none uppercase scramble-target\" data-text=\"TRENDING_SYSTEMS\" data-kid=\"68\">TRENDING_SYSTEMS</h2>\n          <div class=\"font-mono text-2xl font-bold uppercase text-[var(--neon-chartreuse)] bg-[var(--ink-black)] px-6 py-2 border-[5px] border-[var(--snow-white)]\" data-kid=\"69\">SYNCED_NODES: 100%</div>\n        </div>\n\n        <div class=\"grid-container\" data-kid=\"70\">\n          <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 items-start\" data-kid=\"71\">\n            \n            \n            <div class=\"product-card md:col-span-7 group relative bg-[var(--ink-black)] brutalist-border p-10 hover:bg-[var(--snow-white)] hover:text-[var(--ink-black)] hover:transition-colors hover:duration-300 hard-offset -rotate-2\" data-kid=\"72\">\n              <div class=\"absolute -top-10 -left-6 bg-[var(--neon-chartreuse)] text-[var(--ink-black)] px-6 py-2 font-anton text-3xl border-[5px] border-[var(--ink-black)] z-20\" data-kid=\"73\">TOP_SYNC</div>\n              <div class=\"aspect-video bg-white/5 overflow-hidden mb-10 relative\" data-kid=\"74\">\n                <img src=\"https://images.pexels.com/photos/7500610/pexels-photo-7500610.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" alt=\"Product 1\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100\" decoding=\"async\" loading=\"lazy\" data-kid=\"75\">\n              </div>\n              <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6\" data-kid=\"76\">\n                <div data-kid=\"77\">\n                  <h3 class=\"font-anton text-6xl md:text-8xl uppercase leading-none mb-2\" data-kid=\"78\">V0ID_WALK_01</h3>\n                  <p class=\"font-space text-lg font-bold opacity-70 uppercase tracking-widest\" data-kid=\"79\">AERODYNAMIC_TREAD // CARB