      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Cabin:wght@400;500;600;700&display=swap');\n\n  :root {\n    --color-parchment: #F4F0EC;\n    --color-taupe: #9F8170;\n    --color-clay: #E1A95F;\n  }\n\n  body {\n    background-color: var(--color-parchment);\n    color: var(--color-taupe);\n    font-family: 'Cabin', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n    position: relative;\n  }\n\n  /* Paper Grain Texture */\n  body::before {\n    content: \"\";\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    opacity: 0.05;\n    pointer-events: none;\n    z-index: 100;\n    background-image: url(\"https://www.transparenttextures.com/patterns/natural-paper.png\");\n  }\n\n  h1, h2, h3, h4, .font-serif {\n    font-family: 'Fraunces', serif;\n  }\n\n  /* Lenis Horizontal Setup */\n  .horizontal-scroll-wrapper {\n    display: flex;\n    width: fit-content;\n  }\n\n  .section {\n    width: 100vw;\n    height: 100vh;\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* Organic Underline Animation */\n  .nav-link {\n    position: relative;\n    padding-bottom: 4px;\n  }\n  .nav-link::after {\n    content: '';\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 0;\n    height: 2px;\n    background: var(--color-clay);\n    border-radius: 100% 50% 100% 30%; /* Organic shape */\n    transition: width 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n  }\n  .nav-link.active::after, .nav-link:hover::after {\n    width: 100%;\n  }\n\n  /* Peek Carousel */\n  .peek-carousel-container {\n    padding-left: 15%;\n    padding-right: 15%;\n  }\n  .product-card {\n    min-width: 400px;\n  }\n  .product-card-inner {\n    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);\n  }\n  .product-card-inner:hover {\n    transform: translateY(-10px);\n  }\n\n  /* Custom Shadow for Interactivity */\n  .hover-tint-shadow:hover {\n    box-shadow: 0 10px 30px -10px rgba(225, 169, 95, 0.25);\n  }\n\n  /* Arc Fan Setup */\n  .arc-card {\n    /* Transitions removed to avoid GSAP conflict */\n  }\n\n  /* Handwritten Letter Footer Styles */\n  .handwritten-sig {\n    font-family: 'Fraunces', serif;\n    font-style: italic;\n    transform: rotate(-3deg);\n  }\n</style>\n\n\n<nav id=\"tabbed-header\" class=\"fixed top-0 left-0 w-full z-50 px-12 py-8 flex items-center justify-between pointer-events-none\" data-kid=\"1\">\n  <div class=\"pointer-events-auto\" data-kid=\"2\">\n    <a href=\"#\" class=\"text-3xl font-serif text-[var(--color-taupe)] tracking-tight\" data-kid=\"3\">Kintsugi</a>\n  </div>\n  \n  <div class=\"absolute left-1/2 -translate-x-1/2 pointer-events-auto flex space-x-12\" data-kid=\"4\">\n    <a href=\"#hero\" class=\"nav-link active text-sm uppercase tracking-widest font-bold text-[var(--color-taupe)]\" data-kid=\"5\">Objects</a>\n    <a href=\"#categories\" class=\"nav-link text-sm uppercase tracking-widest font-bold text-[var(--color-taupe)]/60\" data-kid=\"6\">Collections</a>\n    <a href=\"#discovery\" class=\"nav-link text-sm uppercase tracking-widest font-bold text-[var(--color-taupe)]/60\" data-kid=\"7\">Discovery</a>\n  </div>\n\n  <div class=\"pointer-events-auto\" data-kid=\"8\">\n    <button class=\"text-sm uppercase tracking-widest font-bold text-[var(--color-taupe)]\" data-kid=\"9\">Basket (2)</button>\n  </div>\n</nav>\n\n\n<div class=\"fixed inset-0 pointer-events-none z-0\" data-kid=\"10\">\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/gooey-molecule.svg\" class=\"absolute top-[15%] right-[8%] w-64 opacity-[0.05] animate-float\" style=\"filter: invert(56%) sepia(13%) saturate(601%) hue-rotate(334deg) brightness(91%) contrast(85%);\" data-kid=\"11\">\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/solid-leaf.svg\" class=\"absolute bottom-[15%] left-[8%] w-48 opacity-[0.05] animate-float-delayed\" style=\"filter: invert(56%) sepia(13%) saturate(601%) hue-rotate(334deg) brightness(91%) contrast(85%);\" data-kid=\"12\">\n</div>\n\n<main class=\"horizontal-scroll-wrapper\" data-kid=\"13\">\n  \n  \n  <section id=\"hero\" class=\"section\" data-kid=\"14\">\n    <div class=\"max-w-[1200px] w-full px-12 pt-20\" data-kid=\"15\">\n      <div id=\"rounded-inset\" class=\"relative aspect-video rounded-[40px] bg-white/20 backdrop-blur-xs p-6 shadow-sm\" data-kid=\"16\">\n        <div class=\"w-full h-full rounded-[32px] overflow-hidden relative shadow-inner\" data-kid=\"17\">\n          <video src=\"https://videos.pexels.com/video-files/12690282/12690282-uhd_2560_1440_24fps.mp4\" poster=\"https://images.pexels.com/videos/12690282/pexels-photo-12690282.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover grayscale-[0.1] contrast-[0.95]\" data-kid=\"18\"></video>\n          <div class=\"absolute inset-0 bg-[var(--color-taupe)]/10 mix-blend-multiply\" data-kid=\"19\"></div>\n          <div class=\"absolute inset-0 bg-gradient-to-t from-black/20 to-transparent\" data-kid=\"20\"></div>\n        </div>\n        \n        <div class=\"absolute -bottom-28 left-12 z-30 max-w-2xl hero-text-trigger\" data-kid=\"21\">\n          <h1 class=\"text-9xl leading-[0.75] text-[var(--color-taupe)] [text-shadow:0_2px_4px_rgba(244,240,236,0.8)]\" data-kid=\"22\">\n            Crafted <br data-kid=\"23\"> <span class=\"pl-24 italic\" data-kid=\"24\">by Time</span>\n          </h1>\n          <p class=\"mt-8 text-xl text-[var(--color-taupe)] max-w-md ml-4 bg-[var(--color-parchment)]/90 backdrop-blur-md p-6 rounded-2xl shadow-sm border border-white/50\" data-kid=\"25\">\n            Slow, deliberate, and deeply human. Our ceramics carry the thumbprints of the artisans who shaped them.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"categories\" class=\"section bg-white/30\" data-kid=\"26\">\n    <div class=\"flex flex-col items-center justify-center w-full\" data-kid=\"27\">\n      <div class=\"text-center mb-24\" data-kid=\"28\">\n        <span class=\"text-[var(--color-clay)] uppercase tracking-widest text-xs mb-4 block\" data-kid=\"29\">Curated Editions</span>\n        <h2 class=\"text-6xl text-[var(--color-taupe)]\" data-kid=\"30\">Nature’s Palette</h2>\n      </div>\n\n      <div class=\"relative w-full max-w-6xl h-[500px] flex items-center justify-center\" data-kid=\"31\">\n        \n        <div class=\"arc-container flex items-center justify-center\" data-kid=\"32\">\n          <div class=\"arc-card absolute w-56 h-80 rounded-full overflow-hidden shadow-xl\" data-rotate=\"-20\" data-x=\"-320\" data-y=\"40\" data-kid=\"33\">\n            <img src=\"https://images.unsplash.com/photo-1729189566211-252094749db5?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Tableware\" data-kid=\"34\">\n            <div class=\"absolute inset-0 bg-black/10\" data-kid=\"35\"></div>\n            <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"36\"><p class=\"italic text-xl\" data-kid=\"37\">Tableware</p></div>\n          </div>\n          <div class=\"arc-card absolute w-56 h-80 rounded-full overflow-hidden shadow-xl\" data-rotate=\"-10\" data-x=\"-160\" data-y=\"10\" data-kid=\"38\">\n            <img src=\"https://images.unsplash.com/photo-1682421938316-4b186e25174c?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Textiles\" data-kid=\"39\">\n            <div class=\"absolute inset-0 bg-black/10\" data-kid=\"40\"></div>\n            <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"41\"><p class=\"italic text-xl\" data-kid=\"42\">Textiles</p></div>\n          </div>\n          <div class=\"arc-card absolute w-60 h-[360px] rounded-full overflow-hidden shadow-2xl z-10\" data-rotate=\"0\" data-x=\"0\" data-y=\"-20\" data-kid=\"43\">\n            <img src=\"https://images.unsplash.com/photo-1665512594386-051aad8b9f68?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Ceramics\" data-kid=\"44\">\n            <div class=\"absolute inset-0 bg-black/10\" data-kid=\"45\"></div>\n            <div class=\"absolute bottom-12 left-0 right-0 text-center text-white\" data-kid=\"46\"><p class=\"italic text-2xl font-bold\" data-kid=\"47\">Ceramics</p></div>\n          </div>\n          <div class=\"arc-card absolute w-56 h-80 rounded-full overflow-hidden shadow-xl\" data-rotate=\"10\" data-x=\"160\" data-y=\"10\" data-kid=\"48\">\n            <img src=\"https://images.pexels.com/photos/31935727/pexels-photo-31935727.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-full object-cover\" alt=\"Woodwork\" data-kid=\"49\">\n            <div class=\"absolute inset-0 bg-black/10\" data-kid=\"50\"></div>\n            <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"51\"><p class=\"italic text-xl\" data-kid=\"52\">Woodwork</p></div>\n          </div>\n          <div class=\"arc-card absolute w-56 h-80 rounded-full overflow-hidden shadow-xl\" data-rotate=\"20\" data-x=\"320\" data-y=\"40\" data-kid=\"53\">\n            <img src=\"https://images.pexels.com/photos/15361090/pexels-photo-15361090.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-full object-cover\" alt=\"Stone\" data-kid=\"54\">\n            <div class=\"absolute inset-0 bg-black/10\" data-kid=\"55\"></div>\n            <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"56\"><p class=\"italic text-xl\" data-kid=\"57\">Stone</p></div>\n          </div>\n        </div>\n        <div class=\"absolute bottom-0 w-4 h-4 rounded-full bg-[var(--color-clay)]\" data-kid=\"58\"></div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"trending\" class=\"section\" data-kid=\"59\">\n    <div class=\"w-full\" data-kid=\"60\">\n      <div class=\"px-24 mb-16 flex items-end justify-between\" data-kid=\"61\">\n        <div data-kid=\"62\">\n          <span class=\"text-[var(--color-clay)] uppercase tracking-widest text-xs mb-4 block\" data-kid=\"63\">New Arrivals</span>\n          <h2 class=\"text-6xl text-[var(--color-taupe)]\" data-kid=\"64\">Objects of Devotion</h2>\n        </div>\n        <a href=\"#\" class=\"text-sm uppercase tracking-widest font-bold border-b border-[var(--color-taupe)]/30 pb-1\" data-kid=\"65\">View Collection</a>\n      </div>\n      \n      <div id=\"peek-carousel\" class=\"flex space-x-12 overflow-x-auto snap-x snap-mandatory peek-carousel-container no-scrollbar pb-12\" data-kid=\"66\">\n        \n        <div class=\"product-card snap-center group\" data-kid=\"67\">\n          <div class=\"product-card-inner aspect-[4/5] overflow-hidden rounded-2xl bg-[#E8E4E0] relative hover-tint-shadow\" data-kid=\"68\">\n            <img src=\"https://images.unsplash.com/photo-1660766474256-bb3e489b412b?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700\" alt=\"Lunar Vase\" data-kid=\"69\">\n          </div>\n          <div class=\"mt-6 flex justify-between items-start px-2\" data-kid=\"70\">\n            <div data-kid=\"71\">\n              <h4 class=\"text-2xl font-serif\" data-kid=\"72\">Lunar Vase</h4>\n              <p class=\"text-sm text-[var(--color-taupe)]/60\" data-kid=\"73\">Smoke Fired Clay</p>\n            </div>\n            <span class=\"text-lg font-bold\" data-kid=\"74\">$185</span>\n          </div>\n        </div>\n        \n        <div class=\"product-card snap-center group\" data-kid=\"75\">\n          <div class=\"product-card-inner aspect-[4/5] overflow-hidden rounded-2xl bg-[#E8E4E0] relative hover-tint-shadow\" data-kid=\"76\">\n            <img src=\"https://images.pexels.com/photos/12268992/pexels-photo-12268992.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700\" alt=\"Driftwood Tray\" data-kid=\"77\">\n          </div>\n          <div class=\"mt-6 flex justify-between items-start px-2\" data-kid=\"78\">\n            <div data-kid=\"79\">\n              <h4 class=\"text-2xl font-serif\" data-kid=\"80\">Driftwood Tray</h4>\n              <p class=\"text-sm text-[var(--color-taupe)]/60\" data-kid=\"81\">Hand-carved Oak</p>\n            </div>\n            <span class=\"text-lg font-bold\" data-kid=\"82\">$140</span>\n          </div>\n        </div>\n        \n        <div class=\"product-card snap-center group\" data-kid=\"83\">\n          <div class=\"product-card-inner aspect-[4/5] overflow-hidden rounded-2xl bg-[#E8E4E0] relative hover-tint-shadow\" data-kid=\"84\">\n            <img src=\"https://images.pexels.com/photos/6739697/pexels-photo-6739697.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700\" alt=\"Earth Bowl\" data-kid=\"85\">\n          </div>\n          <div class=\"mt-6 flex justify-between items-start px-2\" data-kid=\"86\">\n            <div data-kid=\"87\">\n              <h4 class=\"text-2xl font-serif\" data-kid=\"88\">Earth Bowl</h4>\n              <p class=\"text-sm text-[var(--color-taupe)]/60\" data-kid=\"89\">Raw Terracotta</p>\n            </div>\n            <span class=\"text-lg font-bold\" data-kid=\"90\">$95</span>\n          </div>\n        </div>\n        \n        <div class=\"product-card snap-center group\" data-kid=\"91\">\n          <div class=\"product-card-inner aspect-[4/5] overflow-hidden rounded-2xl bg-[#E8E4E0] relative hover-tint-shadow\" data-kid=\"92\">\n            <img src=\"https://images.pexels.com/photos/37912697/pexels-photo-37912697.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700\" alt=\"Silk Thread\" data-kid=\"93\">\n          </div>\n          <div class=\"mt-6 flex justify-between items-start px-2\" data-kid=\"94\">\n            <div data-kid=\"95\">\n              <h4 class=\"text-2xl font-serif\" data-kid=\"96\">Stone Vessel</h4>\n              <p class=\"text-sm text-[var(--color-taupe)]/60\" data-kid=\"97\">Lava Stone</p>\n            </div>\n            <span class=\"text-lg font-bold\" data-kid=\"98\">$210</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"discovery\" class=\"section\" data-kid=\"99\">\n    <div class=\"w-full h-full flex\" data-kid=\"100\">\n      <div class=\"w-1/2 h-full relative overflow-hidden\" data-kid=\"101\">\n        <img src=\"https://images.unsplash.com/photo-1772268485810-29dc9d231f26?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.2]\" alt=\"Serene Sunlight\" data-kid=\"102\">\n        <div class=\"absolute inset-0 bg-[var(--color-clay)]/10 mix-blend-overlay\" data-kid=\"103\"></div>\n      </div>\n      <div class=\"w-1/2 h-full flex items-center justify-center p-24 bg-white/40 backdrop-blur-sm\" data-kid=\"104\">\n        <div class=\"max-w-md w-full onboarding-fade-trigger\" data-kid=\"105\">\n          <span class=\"text-[var(--color-clay)] uppercase tracking-widest text-xs mb-4 block\" data-kid=\"106\">01 / The Journey</span>\n          <h2 class=\"text-5xl text-[var(--color-taupe)] leading-tight mb-12\" data-kid=\"107\">How do you wish to feel in your space today?</h2>\n          \n          <div class=\"space-y-4\" data-kid=\"108\">\n            <button class=\"w-full text-left p-6 border border-[var(--color-taupe)]/20 rounded-full hover:bg-[var(--color-clay)]/10 hover:border-[var(--color-clay)] transition-all duration-500 flex items-center group\" data-kid=\"109\">\n              <span class=\"w-8 h-8 rounded-full border border-current flex items-center justify-center text-xs mr-6 italic group-hover:bg-[var(--color-clay)] group-hover:text-white transition-all\" data-kid=\"110\">a</span>\n              <span class=\"text-lg group-hover:translate-x-1 transition-transform\" data-kid=\"111\">Quiet and Reflective</span>\n            </button>\n            <button class=\"w-full text-left p-6 border border-[var(--color-taupe)]/20 rounded-full hover:bg-[var(--color-clay)]/10 hover:border-[var(--color-clay)] transition-all duration-500 flex items-center group\" data-kid=\"112\">\n              <span class=\"w-8 h-8 rounded-full border border-current flex items-center justify-center text-xs mr-6 italic group-hover:bg-[var(--color-clay)] group-hover:text-white transition-all\" data-kid=\"113\">b</span>\n              <span class=\"text-lg group-hover:translate-x-1 transition-transform\" data-kid=\"114\">Warm and Connected</span>\n            </button>\n            <button class=\"w-full text-left p-6 border border-[var(--color-taupe)]/20 rounded-full hover:bg-[var(--color-clay)]/10 hover:border-[var(--color-clay)] transition-all duration-500 flex items-center group\" data-kid=\"115\">\n              <span class=\"w-8 h-8 rounded-full border border-current flex items-center justify-center text-xs mr-6 italic group-hover:bg-[var(--color-clay)] group-hover:text-white transition-all\" data-kid=\"116\">c</span>\n              <span class=\"text-lg group-hover:translate-x-1 transition-transform\" data-kid=\"117\">Energized by Nature</span>\n            </button>\n          </div>\n          \n          <div class=\"mt-16 flex space-x-2\" data-kid=\"118\">\n            <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-clay)]\" data-kid=\"119\"></div>\n            <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-taupe)]/20\" data-kid=\"120\"></div>\n            <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-taupe)]/20\" data-kid=\"121\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"footer\" class=\"section\" data-kid=\"122\">\n    <div class=\"w-full flex flex-col items-center justify-center text-center p-24\" data-kid=\"123\">\n      <div class=\"max-w-2xl mb-24\" data-kid=\"124\">\n        <h3 class=\"text-3xl mb-8 leading-relaxed italic text-[var(--color-taupe)]\" data-kid=\"125\">\"In the Japanese philosophy of Wabi-sabi, imperfection is the core of beauty. We celebrate the crack, the smudge, and the soul.\"</h3>\n        <p class=\"text-[var(--color-taupe)]/60 font-sans tracking-wide uppercase text-xs\" data-kid=\"126\">A note from our founders</p>\n      </div>\n      \n      <div class=\"w-full border-t border-[var(--color-taupe)]/10 pt-24 flex flex-col items-center\" data-kid=\"127\">\n        <a href=\"#\" class=\"text-4xl font-serif text-[var(--color-taupe)] tracking-tight mb-12\" data-kid=\"128\">Kintsugi</a>\n        \n        <nav class=\"flex space-x-12 mb-16\" data-kid=\"129\">\n          <a href=\"#\" class=\"text-sm uppercase tracking-widest hover:text-[var(--color-clay)] transition-colors\" data-kid=\"130\">Our Story</a>\n          <a href=\"#\" class=\"text-sm uppercase tracking-widest hover:text-[var(--color-clay)] transition-colors\" data-kid=\"131\">Sustainability</a>\n          <a href=\"#\" class=\"text-sm uppercase tracking-widest hover:text-[var(--color-clay)] transition-colors\" data-kid=\"132\">Shipping</a>\n          <a href=\"#\" class=\"text-sm uppercase tracking-widest hover:text-[var(--color-clay)] transition-colors\" data-kid=\"133\">Contact</a>\n        </nav>\n        \n        <div class=\"flex space-x-8 mb-24\" data-kid=\"134\">\n          <a href=\"#\" class=\"w-10 h-10 rounded-full border border-[var(--color-taupe)]/20 flex items-center justify-center hover:bg-[var(--color-taupe)]/5 transition-colors\" data-kid=\"135\"><i class=\"ph ph-instagram-logo\" data-kid=\"136\"></i></a>\n          <a href=\"#\" class=\"w-10 h-10 rounded-full border border-[var(--color-taupe)]/20 flex items-center justify-center hover:bg-[var(--color-taupe)]/5 transition-colors\" data-kid=\"137\"><i class=\"ph ph-pinterest-logo\" data-kid=\"138\"></i></a>\n          <a href=\"#\" class=\"w-10 h-10 rounded-full border border-[var(--color-taupe)]/20 flex items-center justify-center hover:bg-[var(--color-taupe)]/5 transition-colors\" data-kid=\"139\"><i class=\"ph ph-envelope-simple\" data-kid=\"140\"></i></a>\n        </div>\n        \n        <div class=\"w-full border-t border-[var(--color-taupe)]/10 pt-12 flex justify-between items-center text-[var(--color-taupe)]/40 text-xs uppercase tracking-widest\" data-kid=\"141\">\n          <span data-kid=\"142\">&copy; 2024 Kintsugi Artisanal</span>\n          <div class=\"handwritten-sig text-xl text-[var(--color-clay)]\" data-kid=\"143\">Made with care</div>\n          <span data-kid=\"144\">Stockholm & Kyoto</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"145\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"146\"></script>\n<script type=\"module\" data-kid=\"147\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Lenis for horizontal scrolling\n  const lenis = new Lenis({\n    orientation: 'horizontal',\n    gestureOrientation: 'both',\n    smoothWheel: true,\n    wheelMultiplier: 1.2,\n  });\n\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Sync GSAP with Lenis\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Hero Text Animation\n  gsap.from(\".hero-text-trigger h1\", {\n    y: 100,\n    opacity: 0,\n    duration: 1.5,\n    ease: \"power4.out\",\n    delay: 0.5\n  });\n  gsap.from(\".hero-text-trigger p\", {\n    y: 30,\n    opacity: 0,\n    duration: 1,\n    ease: \"power3.out\",\n    delay: 1.2\n  });\n\n  // Horizontal Scroll Tween\n  const scrollWrapper = document.querySelector(\".horizontal-scroll-wrapper\");\n  const scrollTween = gsap.to(scrollWrapper, {\n    x: () => -(scrollWrapper.scrollWidth - window.innerWidth),\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"main\",\n      start: \"top top\",\n      end: () => \"+=\" + (scrollWrapper.scrollWidth - window.innerWidth), // Adjusted end point\n      scrub: 1,\n      pin: true,\n      invalidateOnRefresh: true,\n    }\n  });\n\n  // Arc Fan Animation (Scroll-triggered)\n  const arcCards = document.querySelectorAll('.arc-card');\n  gsap.set(arcCards, { opacity: 0, scale: 0.8 });\n  \n  ScrollTrigger.create({\n    trigger: \"#categories\",\n    start: \"left center\",\n    containerAnimation: scrollTween,\n    onEnter: () => {\n      arcCards.forEach((card, i) => {\n        const targetRotate = card.getAttribute('data-rotate');\n        const targetX = card.getAttribute('data-x');\n        const targetY = card.getAttribute('data-y');\n        \n        gsap.to(card, {\n          opacity: 1,\n          scale: 1,\n          rotate: targetRotate,\n          x: targetX,\n          y: targetY,\n          duration: 1.5,\n          delay: i * 0.1,\n          ease: \"expo.out\"\n        });\n      });\n    }\n  });\n\n  // Product Cards Entrance\n  gsap.from(\".product-card\", {\n    scrollTrigger: {\n      trigger: \"#trending\",\n      containerAnimation: scrollTween,\n      start: \"left center\",\n    },\n    x: 100,\n    opacity: 0,\n    stagger: 0.1,\n    duration: 1.5,\n    ease: \"power3.out\"\n  });\n\n  // Discovery Fade In\n  gsap.from(\".onboarding-fade-trigger\", {\n    scrollTrigger: {\n      trigger: \"#discovery\",\n      containerAnimation: scrollTween,\n      start: \"left center\",\n    },\n    opacity: 0,\n    x: 50,\n    duration: 1.5,\n    ease: \"power2.out\"\n  });\n\n  // Ambient Floating Animations (Motion.js)\n  animate(\".animate-float\", \n    { y: [-20, 20], rotate: [0, 10] }, \n    { duration: 4, repeat: Infinity, direction: \"alternate\", easing: \"ease-in-out\" }\n  );\n  animate(\".animate-float-delayed\", \n    { y: [15, -15], rotate: [0, -8] }, \n    { duration: 5, repeat: Infinity, direction: \"alternate\", easing: \"ease-in-out\", delay: 1 }\n  );\n\n\n</script>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"148\">\n<script src=\"https://unpkg.com/@phosphor-icons/web\" data-kid=\"149\"></script>\n",
      "comments": [],
      "created": "2026-07-10T04:10:24.131067+00:00",
      "modified": "2026-07-10T04:10:24.131067+00:00",
      "id": "var_ec0cb7d5ab6b",
      "viewportScrollY": 0
    },
    "var_f786b6b19388": {
      "type": "variant",
      "label": "Editorial Luxury",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 3080,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..900&family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --parchment: #F4F0EC;\n    --onyx: #111111;\n    --brandy: #882D17;\n    --brandy-light: #A64B35;\n  }\n\n  body {\n    background-color: var(--parchment);\n    color: var(--onyx);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip; /* Prevent sticky break */\n  }\n\n  .font-serif { font-family: 'Bodoni Moda', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .vertical-text {\n    writing-mode: vertical-rl;\n    transform: rotate(180deg);\n  }\n\n  .nav-link::after {\n    content: '';\n    position: absolute;\n    bottom: -2px;\n    left: 0;\n    width: 0%;\n    height: 1px;\n    background-color: var(--onyx);\n    transition: width 0.3s ease;\n  }\n  .nav-link:hover::after { width: 100%; }\n\n  /* Grid Layouts */\n  .photo-wall {\n    display: grid;\n    grid-template-columns: repeat(6, 1fr);\n    grid-template-rows: repeat(4, 200px);\n    gap: 1.5rem;\n  }\n\n  .photo-wall-item:nth-child(1) { grid-column: span 3; grid-row: span 3; }\n  .photo-wall-item:nth-child(2) { grid-column: span 2; grid-row: span 2; }\n  .photo-wall-item:nth-child(3) { grid-column: span 1; grid-row: span 4; }\n  .photo-wall-item:nth-child(4) { grid-column: span 2; grid-row: span 2; }\n  .photo-wall-item:nth-child(5) { grid-column: span 3; grid-row: span 1; }\n\n  /* Custom Scrollbar for modern look */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: var(--parchment); }\n  ::-webkit-scrollbar-thumb { background: var(--onyx); border-radius: 10px; }\n\n  .discovery-option:hover {\n    color: var(--brandy);\n    border-color: var(--brandy);\n    padding-left: 1rem;\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<div id=\"smooth-wrapper\" data-kid=\"2\">\n  <div id=\"smooth-content\" data-kid=\"3\">\n    \n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 bg-[var(--parchment)] border-b border-[var(--onyx)]/5 px-10 py-6 grid grid-cols-3 items-center\" data-kid=\"4\">\n      <div class=\"flex gap-10 text-[10px] uppercase tracking-[0.3em] font-bold\" data-kid=\"5\">\n        <a href=\"#\" class=\"nav-link relative\" data-kid=\"6\">Shop</a>\n        <a href=\"#\" class=\"nav-link relative\" data-kid=\"7\">Archive</a>\n        <a href=\"#\" class=\"nav-link relative\" data-kid=\"8\">Journal</a>\n      </div>\n      \n      <div class=\"text-center\" data-kid=\"9\">\n        <a href=\"#\" class=\"font-serif italic text-4xl lowercase tracking-tighter font-black\" data-kid=\"10\">editorial</a>\n      </div>\n      \n      <div class=\"flex justify-end gap-8 items-center\" data-kid=\"11\">\n        <button class=\"hover:text-[var(--brandy)] transition-colors duration-300\" data-kid=\"12\">\n          <i class=\"ti ti-search text-xl\" data-kid=\"13\"></i>\n        </button>\n        <button class=\"hover:text-[var(--brandy)] transition-colors duration-300 relative group\" data-kid=\"14\">\n          <i class=\"ti ti-shopping-bag text-xl\" data-kid=\"15\"></i>\n          <span class=\"absolute -top-2 -right-2 bg-[var(--brandy)] text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-bold\" data-kid=\"16\">0</span>\n        </button>\n      </div>\n    </nav>\n\n    \n    <section class=\"min-h-screen pt-24 grid grid-cols-1 lg:grid-cols-[80px_1fr_1.3fr]\" data-kid=\"17\">\n      \n      <div class=\"border-r border-[var(--onyx)]/10 flex items-center justify-center\" data-kid=\"18\">\n        <span class=\"vertical-text text-[10px] uppercase tracking-[0.5em] font-bold opacity-30\" data-kid=\"19\">\n          The Autumn Narrative / Vol. 04\n        </span>\n      </div>\n\n      \n      <div class=\"flex flex-col justify-center px-16 lg:px-24\" data-kid=\"20\">\n        <div class=\"gsap-hero-content\" data-kid=\"21\">\n          <h1 class=\"hero-item font-serif text-[clamp(4rem,8vw,9rem)] leading-[0.85] tracking-tight mb-10\" data-kid=\"22\">\n            Poetic<br data-kid=\"23\">\n            <span class=\"italic text-[var(--brandy)]\" data-kid=\"24\">Presence.</span>\n          </h1>\n          <p class=\"hero-item font-sans text-lg opacity-70 max-w-sm mb-12 leading-relaxed font-light\" data-kid=\"25\">\n            An exploration of silhouettes that command space while honoring the silence within. Handcrafted in our Milanese atelier.\n          </p>\n          <a href=\"#\" class=\"hero-item inline-flex items-center gap-6 group\" data-kid=\"26\">\n            <span class=\"text-[11px] uppercase tracking-[0.4em] font-bold border-b border-[var(--onyx)] pb-1 transition-colors duration-300 group-hover:border-[var(--brandy)] group-hover:text-[var(--brandy)]\" data-kid=\"27\">Explore the Edit</span>\n            <i class=\"ti ti-arrow-right text-lg transition-transform duration-300 group-hover:translate-x-2 group-hover:text-[var(--brandy)]\" data-kid=\"28\"></i>\n          </a>\n        </div>\n      </div>\n\n      \n      <div class=\"relative overflow-hidden h-full\" data-kid=\"29\">\n        <img src=\"https://images.unsplash.com/photo-1556065685-813b084639c5?auto=format&w=1400&q=80&fit=crop\" alt=\"Fashion model in silhouette\" class=\"w-full h-full object-cover grayscale-[30%]\" data-scroll data-scroll-speed=\"-0.2\" loading=\"lazy\" decoding=\"async\" data-kid=\"30\">\n        <div class=\"absolute bottom-10 right-10 text-white text-[10px] uppercase tracking-[0.3em] font-bold mix-blend-difference\" data-kid=\"31\">\n          Model: Briona / SS24\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-40 px-10 max-w-[1600px] mx-auto\" data-kid=\"32\">\n      <div class=\"flex justify-between items-end mb-16 px-4\" data-kid=\"33\">\n        <h2 class=\"font-serif text-6xl italic leading-none\" data-kid=\"34\">Curated Spaces</h2>\n        <p class=\"font-sans text-xs uppercase tracking-[0.3em] opacity-40 max-w-xs text-right\" data-kid=\"35\">\n          A collection of rare finds and artisanal essentials.\n        </p>\n      </div>\n\n      <div class=\"photo-wall\" data-kid=\"36\">\n        \n        <div class=\"photo-wall-item relative group overflow-hidden\" data-kid=\"37\">\n          <div class=\"photo-parallax w-full h-full\" data-kid=\"38\">\n            <img src=\"https://images.pexels.com/photos/6275942/pexels-photo-6275942.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" alt=\"Textured woven fabric\" data-kid=\"39\">\n          </div>\n          <div class=\"absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"40\"></div>\n          <span class=\"absolute bottom-8 left-8 text-white font-sans text-[10px] uppercase tracking-[0.3em] font-bold translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500\" data-kid=\"41\">Soft Goods</span>\n        </div>\n        \n        \n        <div class=\"photo-wall-item relative group overflow-hidden\" data-kid=\"42\">\n          <div class=\"photo-parallax w-full h-full\" data-kid=\"43\">\n            <img src=\"https://images.pexels.com/photos/4203100/pexels-photo-4203100.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" alt=\"Ceramic vase\" data-kid=\"44\">\n          </div>\n          <span class=\"absolute bottom-8 left-8 bg-white/90 px-4 py-2 font-sans text-[9px] uppercase tracking-[0.3em] font-bold\" data-kid=\"45\">Sculptural Objects</span>\n        </div>\n\n        \n        <div class=\"photo-wall-item relative group overflow-hidden\" data-kid=\"46\">\n          <div class=\"photo-parallax w-full h-full\" data-kid=\"47\">\n            <img src=\"https://images.unsplash.com/photo-1522123472015-2d9f7ee5608d?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" alt=\"Architectural shadows\" data-kid=\"48\">\n          </div>\n          <span class=\"absolute top-8 right-8 text-white font-serif italic text-2xl lowercase mix-blend-difference\" data-kid=\"49\">atmosphere</span>\n        </div>\n\n        \n        <div class=\"photo-wall-item relative group overflow-hidden\" data-kid=\"50\">\n          <div class=\"photo-parallax w-full h-full\" data-kid=\"51\">\n            <img src=\"https://images.pexels.com/photos/6276020/pexels-photo-6276020.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" alt=\"Textured fabric\" data-kid=\"52\">\n          </div>\n          <span class=\"absolute bottom-8 left-8 bg-white/90 px-4 py-2 font-sans text-[9px] uppercase tracking-[0.3em] font-bold\" data-kid=\"53\">Raw Textures</span>\n        </div>\n\n        \n        <div class=\"photo-wall-item relative group overflow-hidden\" data-kid=\"54\">\n          <div class=\"photo-parallax w-full h-full\" data-kid=\"55\">\n            <img src=\"https://images.unsplash.com/photo-1707135017559-8b3e673b18ed?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" alt=\"Fashion silhouette\" data-kid=\"56\">\n          </div>\n          <span class=\"absolute bottom-8 right-8 text-[var(--parchment)] font-sans text-[10px] uppercase tracking-[0.4em] font-bold\" data-kid=\"57\">Apparel</span>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-40 bg-[var(--onyx)] text-[var(--parchment)]\" data-kid=\"58\">\n      <div class=\"px-10 mb-20\" data-kid=\"59\">\n        <span class=\"font-sans text-[10px] uppercase tracking-[0.5em] font-bold opacity-30 mb-6 block\" data-kid=\"60\">Curated Trending</span>\n        <h2 class=\"font-serif text-8xl leading-none\" data-kid=\"61\">The Artifacts.</h2>\n      </div>\n\n      <div class=\"grid grid-cols-1 lg:grid-cols-[1fr_500px] items-end px-10 relative\" data-kid=\"62\">\n        \n        <div class=\"w-full h-[85vh] overflow-hidden\" data-kid=\"63\">\n          <img src=\"https://images.pexels.com/photos/6070129/pexels-photo-6070129.jpeg?auto=compress&cs=tinysrgb&w=1400&q=80\" class=\"w-full h-full object-cover grayscale opacity-80\" alt=\"Trending product\" data-kid=\"64\">\n        </div>\n\n        \n        <div class=\"bg-[var(--parchment)] text-[var(--onyx)] p-16 -ml-32 mb-24 z-10 relative shadow-2xl\" data-kid=\"65\">\n          <span class=\"text-[var(--brandy)] text-[10px] uppercase tracking-[0.4em] font-black block mb-6\" data-kid=\"66\">Trending 01</span>\n          <h3 class=\"font-serif text-5xl mb-8 leading-tight\" data-kid=\"67\">Musa Marble<br data-kid=\"68\"><span class=\"italic text-[var(--brandy)]\" data-kid=\"69\">Plinth Bowl</span></h3>\n          <p class=\"font-sans text-sm opacity-60 mb-12 leading-relaxed font-light\" data-kid=\"70\">\n            Each bowl is hand-hewn from a singular block of Carrara marble, ensuring a unique topography of veins and textures.\n          </p>\n          <div class=\"flex justify-between items-center border-t border-[var(--onyx)]/10 pt-10\" data-kid=\"71\">\n            <span class=\"font-serif text-3xl font-bold\" data-kid=\"72\">$1,850</span>\n            <button class=\"bg-[var(--onyx)] text-white px-10 py-5 text-[10px] uppercase tracking-[0.3em] font-bold hover:bg-[var(--brandy)] transition-colors duration-500\" data-kid=\"73\">\n              Add to Bag\n            </button>\n          </div>\n          \n          \n          <div class=\"absolute -top-12 -right-12 w-32 h-32 border-4 border-[var(--parchment)] shadow-xl overflow-hidden hidden lg:block\" data-kid=\"74\">\n            <img src=\"https://images.pexels.com/photos/6825577/pexels-photo-6825577.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" class=\"w-full h-full object-cover\" alt=\"Detail view\" data-kid=\"75\">\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-40 px-10 flex flex-col items-center justify-center min-h-[60vh]\" data-kid=\"76\">\n      <div class=\"max-w-4xl w-full text-center\" data-kid=\"77\">\n        <span class=\"font-sans text-[10px] uppercase tracking-[0.4em] font-bold opacity-30 mb-16 block\" data-kid=\"78\">Discovery Flow</span>\n        <h2 class=\"font-serif text-[clamp(3rem,6vw,5rem)] italic mb-20 leading-tight\" data-kid=\"79\">\n          \"What defines the energy of your living space?\"\n        </h2>\n        \n        <div class=\"space-y-6 max-w-xl mx-auto\" data-kid=\"80\">\n          <button class=\"discovery-option w-full py-8 border-b border-[var(--onyx)]/10 text-left font-sans text-xl font-light flex justify-between items-center group hover:transition-all hover:duration-300\" data-kid=\"81\">\n            <span data-kid=\"82\">A Sanctuary of Silence</span>\n            <i class=\"ti ti-arrow-right opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-transform duration-300\" data-kid=\"83\"></i>\n          </button>\n          <button class=\"discovery-option w-full py-8 border-b border-[var(--onyx)]/10 text-left font-sans text-xl font-light flex justify-between items-center group hover:transition-all hover:duration-300\" data-kid=\"84\">\n            <span data-kid=\"85\">An Ode to Architectural Form</span>\n            <i class=\"ti ti-arrow-right opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-transform duration-300\" data-kid=\"86\"></i>\n          </button>\n          <button class=\"discovery-option w-full py-8 border-b border-[var(--onyx)]/10 text-left font-sans text-xl font-light flex justify-between items-center group hover:transition-all hover:duration-300\" data-kid=\"87\">\n            <span data-kid=\"88\">The Warmth of Natural Rawness</span>\n            <i class=\"ti ti-arrow-right opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-transform duration-300\" data-kid=\"89\"></i>\n          </button>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"bg-[var(--parchment)] px-10 py-20 border-t border-[var(--onyx)]/10\" data-kid=\"90\">\n      <div class=\"flex justify-between items-end mb-20\" data-kid=\"91\">\n        <div data-kid=\"92\">\n          <a href=\"#\" class=\"font-serif italic text-6xl lowercase tracking-tighter font-black mb-8 block\" data-kid=\"93\">editorial</a>\n          <div class=\"flex gap-10 text-[9px] uppercase tracking-[0.3em] font-bold opacity-40\" data-kid=\"94\">\n            <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"95\">Sustainability</a>\n            <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"96\">Shipping</a>\n            <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"97\">Journal</a>\n          </div>\n        </div>\n        \n        <div class=\"max-w-md w-full\" data-kid=\"98\">\n          <p class=\"font-sans text-[10px] uppercase tracking-[0.3em] opacity-40 mb-6\" data-kid=\"99\">Stay Curated</p>\n          <form class=\"flex border-b border-[var(--onyx)] pb-4 group\" data-kid=\"100\">\n            <input type=\"email\" placeholder=\"YOUR EMAIL ADDRESS\" class=\"bg-transparent w-full text-xs uppercase tracking-[0.2em] font-bold outline-none placeholder:text-[var(--onyx)]/20\" data-kid=\"101\">\n            <button type=\"submit\" class=\"ti ti-arrow-right text-xl group-hover:translate-x-2 transition-transform duration-300\" data-kid=\"102\"></button>\n          </form>\n        </div>\n      </div>\n\n      <div class=\"flex justify-between items-center pt-10 border-t border-[var(--onyx)]/5\" data-kid=\"103\">\n        <span class=\"text-[9px] uppercase tracking-[0.4em] opacity-30\" data-kid=\"104\">© 2024 Editorial Collective.</span>\n        <div class=\"flex gap-6 opacity-30\" data-kid=\"105\">\n          <i class=\"ti ti-brand-instagram text-lg hover:opacity-100 cursor-pointer\" data-kid=\"106\"></i>\n          <i class=\"ti ti-brand-pinterest text-lg hover:opacity-100 cursor-pointer\" data-kid=\"107\"></i>\n          <i class=\"ti ti-brand-x text-lg hover:opacity-100 cursor-pointer\" data-kid=\"108\"></i>\n        </div>\n      </div>\n    </footer>\n\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"109\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"110\"></script>\n<script type=\"module\" data-kid=\"111\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Initialize Lenis\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    smoothWheel: true,\n  })\n\n  // GSAP Ticker Integration\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // GSAP Animations\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Reveal\n  gsap.from(\".hero-item\", {\n    autoAlpha: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power4.out\"\n  });\n\n  // Photo Wall Items Reveal\n  gsap.from(\".photo-wall-item\", {\n    scrollTrigger: {\n      trigger: \".photo-wall\",\n      start: \"top 80%\",\n    },\n    autoAlpha: 0,\n    y: 60,\n    duration: 1,\n    stagger: 0.15,\n    ease: \"power3.out\"\n  });\n\n  // Trending Section Parallax\n  gsap.to(\".photo-parallax\", {\n    y: -40,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \".photo-wall\",\n      start: \"top bottom\",\n      end: \"bottom top\",\n      scrub: true\n    }\n  });\n\n  // Discovery Options Sweep\n  gsap.from(\".discovery-option\", {\n    scrollTrigger: {\n      trigger: \".discovery-option\",\n      start: \"top 85%\",\n    },\n    autoAlpha: 0,\n    x: -30,\n    duration: 0.8,\n    stagger: 0.2,\n    ease: \"power2.out\"\n  });\n\n</script>\n",
