    },
    "var_2e732fb8c940": {
      "type": "variant",
      "label": "Retrowave Arcade",
      "parentId": "var_18a40113f029",
      "themeId": null,
      "rect": {
        "x": 9240,
        "y": -86.99983513534744,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Righteous&family=VT323&display=swap');\n\n  :root {\n    --midnight: #191970;\n    --magenta: #FF00FF;\n    --cyan: #00FFFF;\n    --white: #FFFFFF;\n  }\n\n  body {\n    background-color: var(--midnight);\n    color: var(--white);\n    font-family: 'VT323', monospace;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-righteous { font-family: 'Righteous', cursive; }\n  .font-vt323 { font-family: 'VT323', monospace; }\n\n  /* Neon Tube Borders */\n  .neon-tube-magenta {\n    border: 3px solid var(--magenta);\n    box-shadow: 0 0 5px var(--magenta), 0 0 15px var(--magenta), inset 0 0 5px var(--magenta);\n  }\n  \n  .neon-tube-cyan {\n    border: 3px solid var(--cyan);\n    box-shadow: 0 0 5px var(--cyan), 0 0 15px var(--cyan), inset 0 0 5px var(--cyan);\n  }\n\n  /* Pixel 8-bit Shape */\n  .pixel-8bit {\n    clip-path: polygon(\n      0 6px, 6px 6px, 6px 0, \n      calc(100% - 6px) 0, calc(100% - 6px) 6px, 100% 6px,\n      100% calc(100% - 6px), calc(100% - 6px) calc(100% - 6px), calc(100% - 6px) 100%,\n      6px 100%, 6px calc(100% - 6px), 0 calc(100% - 6px)\n    );\n  }\n\n  /* Gradient Mesh & Aurora */\n  .gradient-mesh {\n    background: linear-gradient(135deg, var(--midnight) 0%, #301934 25%, #4b0082 50%, #191970 100%);\n    background-size: 400% 400%;\n    position: relative;\n  }\n\n  .grid-pattern {\n    background-image: \n      linear-gradient(rgba(0, 255, 255, 0.05) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(0, 255, 255, 0.05) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .aurora-bg {\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle at 50% 50%, var(--magenta) 0%, transparent 50%),\n                radial-gradient(circle at 20% 80%, var(--cyan) 0%, transparent 40%);\n    filter: blur(80px);\n    opacity: 0.15;\n    z-index: 0;\n  }\n\n  /* Rainbow Border */\n  .rainbow-border-container {\n    position: relative;\n    padding: 3px;\n    background: linear-gradient(90deg, #e84343, #e8943d, #e8d43d, #43e87a, #4080e8, #40e8e8, #e8437a);\n    background-size: 200% auto;\n    animation: rainbow-sweep 3s linear infinite;\n  }\n\n  @keyframes rainbow-sweep {\n    0% { background-position: 0% 50%; }\n    100% { background-position: 200% 50%; }\n  }\n\n  /* VHS Card Effect */\n  .vhs-overlay {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), \n                linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));\n    background-size: 100% 3px, 3px 100%;\n    pointer-events: none;\n    z-index: 5;\n  }\n\n  /* Horizontal Scroll Section */\n  .horizontal-section {\n    display: flex;\n    flex-wrap: nowrap;\n    width: 300vw; /* Accommodates multiple screens */\n  }\n\n  .screen {\n    width: 100vw;\n    flex-shrink: 0;\n  }\n\n  .scrollbar-hide::-webkit-scrollbar { display: none; }\n  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }\n\n  /* Custom Cursor */\n  #arcade-cursor {\n    position: fixed;\n    width: 20px;\n    height: 20px;\n    border: 2px solid var(--cyan);\n    pointer-events: none;\n    z-index: 9999;\n    mix-blend-difference: difference;\n    box-shadow: 0 0 10px var(--cyan);\n  }\n  \n  .terminal-cursor {\n    display: inline-block;\n    width: 10px;\n    height: 1.2em;\n    background: var(--cyan);\n    vertical-align: middle;\n    animation: blink 1s step-end infinite;\n  }\n  \n  @keyframes blink { \n    50% { opacity: 0; }\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<div id=\"arcade-cursor\" data-kid=\"2\"></div>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-[100] bg-[var(--midnight)] border-b-4 border-[var(--magenta)] flex h-20\" data-kid=\"3\">\n  <div class=\"flex-1 flex font-righteous\" data-kid=\"4\">\n    <a href=\"#hero\" class=\"flex-1 flex items-center justify-center text-2xl border-r-2 border-[var(--magenta)]/20 hover:bg-[var(--magenta)] hover:text-[var(--midnight)] transition-all duration-300 relative group overflow-hidden\" data-kid=\"5\">\n      <span class=\"relative z-10\" data-kid=\"6\">01_INIT</span>\n      <div class=\"absolute bottom-0 left-0 w-full h-1 bg-[var(--cyan)] neon-tube-cyan translate-y-full group-hover:translate-y-0 transition-transform\" data-kid=\"7\"></div>\n    </a>\n    <a href=\"#features\" class=\"flex-1 flex items-center justify-center text-2xl border-r-2 border-[var(--magenta)]/20 hover:bg-[var(--magenta)] hover:text-[var(--midnight)] transition-all duration-300 relative group overflow-hidden\" data-kid=\"8\">\n      <span class=\"relative z-10\" data-kid=\"9\">02_THE_GRID</span>\n    </a>\n    <a href=\"#products\" class=\"flex-1 flex items-center justify-center text-2xl border-r-2 border-[var(--magenta)]/20 hover:bg-[var(--magenta)] hover:text-[var(--midnight)] transition-all duration-300 relative group overflow-hidden\" data-kid=\"10\">\n      <span class=\"relative z-10\" data-kid=\"11\">03_HARDWARE</span>\n    </a>\n    <a href=\"#drops\" class=\"flex-1 flex items-center justify-center text-2xl border-r-2 border-[var(--magenta)]/20 hover:bg-[var(--magenta)] hover:text-[var(--midnight)] transition-all duration-300 relative group overflow-hidden\" data-kid=\"12\">\n      <span class=\"relative z-10\" data-kid=\"13\">04_VAULT</span>\n    </a>\n    <div class=\"flex-1 flex items-center justify-center text-2xl text-[var(--cyan)] border-l-2 border-[var(--magenta)]/20 animate-pulse px-4\" data-kid=\"14\">\n      HIGH_SCORE: 999,999\n    </div>\n  </div>\n</nav>\n\n<main id=\"main-content\" class=\"pt-20\" data-kid=\"15\">\n  \n  \n  <section id=\"hero\" class=\"min-h-screen flex items-center justify-center gradient-mesh overflow-hidden relative\" data-kid=\"16\">\n    <div class=\"aurora-bg\" data-kid=\"17\"></div>\n    <div class=\"absolute inset-0 grid-pattern opacity-20\" data-kid=\"18\"></div>\n    \n    \n    <div class=\"relative z-10 w-full max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center pt-24 pb-32\" data-kid=\"19\">\n      <div class=\"lg:col-span-7 space-y-10\" data-kid=\"20\">\n        <div class=\"inline-block px-6 py-2 bg-[var(--magenta)] text-[var(--midnight)] text-2xl font-bold pixel-8bit\" data-kid=\"21\">NEW_CONNECTION_ESTABLISHED</div>\n        <h1 class=\"text-8xl md:text-[10rem] font-righteous text-[var(--cyan)] leading-[0.85] tracking-tighter\" data-kid=\"22\">\n          RETRO_MOD <br data-kid=\"23\"> <span class=\"text-[var(--magenta)]\" data-kid=\"24\">SYS_01</span>\n        </h1>\n        <p class=\"text-3xl md:text-4xl text-white/90 uppercase leading-snug max-w-2xl font-vt323 tracking-wide\" data-kid=\"25\">\n          High-fidelity apparel forged in the neon-glow of the 80s arcade pulse. Synchronize your physical form to the digital grid.\n        </p>\n        <button class=\"group relative px-16 py-8 bg-[var(--magenta)] text-[var(--midnight)] font-righteous text-4xl pixel-8bit hover:scale-110 active:scale-95 transition-all shadow-[0_0_40px_rgba(255,0,255,0.6)]\" data-kid=\"26\">\n          INITIATE_UP_LINK\n          <div class=\"absolute inset-0 border-2 border-[var(--cyan)] translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform\" data-kid=\"27\"></div>\n        </button>\n      </div>\n      \n      <div class=\"lg:col-span-5 relative\" data-kid=\"28\">\n        <div class=\"absolute inset-0 bg-gradient-to-tr from-[var(--magenta)]/30 to-[var(--cyan)]/30 blur-[100px] scale-150 animate-pulse\" data-kid=\"29\"></div>\n        <div class=\"relative z-10 transform -rotate-6 hover:rotate-0 transition-transform duration-700\" data-kid=\"30\">\n          <div class=\"neon-tube-cyan p-2 pixel-8bit bg-black\" data-kid=\"31\">\n            <img src=\"https://images.pexels.com/photos/15327265/pexels-photo-15327265.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" alt=\"Retro DeLorean\" class=\"w-full h-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\">\n            <div class=\"vhs-overlay\" data-kid=\"33\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"features\" class=\"py-24 bg-[var(--midnight)] relative\" data-kid=\"34\">\n    <div class=\"absolute left-1/2 top-0 bottom-0 w-1 bg-gradient-to-b from-transparent via-[var(--magenta)] to-transparent shadow-[0_0_15px_var(--magenta)] -translate-x-1/2 opacity-50\" data-kid=\"35\"></div>\n    \n    <div class=\"max-w-7xl mx-auto px-6 relative space-y-32\" data-kid=\"36\">\n      \n      \n      <div class=\"feature-row flex flex-col md:flex-row items-center group\" data-kid=\"37\">\n        <div class=\"w-full md:w-[45%] text-right pr-0 md:pr-16 order-2 md:order-1 feature-text-left\" data-kid=\"38\">\n          <h3 class=\"text-5xl font-righteous text-[var(--magenta)] mb-4 uppercase tracking-wider\" data-kid=\"39\">NEON_THREAD_TECH</h3>\n          <p class=\"text-xl text-white/70 leading-relaxed mb-6 font-vt323\" data-kid=\"40\">Proprietary reactive fibers that respond to the pulse of the digital grid. Night-vision optimized visibility.</p>\n          <div class=\"flex justify-end gap-3 text-[var(--cyan)] font-righteous text-lg\" data-kid=\"41\">\n            <span data-kid=\"42\">[ DURABILITY: 99 ]</span>\n            <span data-kid=\"43\">[ GLOW: HIGH ]</span>\n          </div>\n        </div>\n        <div class=\"w-12 h-12 bg-[var(--midnight)] border-4 border-[var(--cyan)] shadow-[0_0_15px_var(--cyan)] rounded-full z-10 relative order-1 md:order-2 mb-8 md:mb-0\" data-kid=\"44\">\n          <div class=\"absolute inset-2 bg-[var(--magenta)] rounded-full animate-ping\" data-kid=\"45\"></div>\n        </div>\n        <div class=\"w-full md:w-[45%] pl-0 md:pl-16 order-3 feature-image-right\" data-kid=\"46\">\n          <div class=\"relative p-1 neon-tube-magenta pixel-8bit overflow-hidden\" data-kid=\"47\">\n            <img src=\"https://images.unsplash.com/photo-1508606572321-901ea443707f?auto=format&w=800&q=80&fit=crop\" alt=\"Neon Rave\" class=\"w-full h-[400px] object-cover grayscale contrast-150 group-hover:grayscale-0 transition-all duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n            <div class=\"vhs-overlay\" data-kid=\"49\"></div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"feature-row flex flex-col md:flex-row items-center group\" data-kid=\"50\">\n        <div class=\"w-full md:w-[45%] pr-0 md:pr-16 order-3 md:order-1 feature-image-left\" data-kid=\"51\">\n          <div class=\"relative p-1 neon-tube-cyan pixel-8bit overflow-hidden\" data-kid=\"52\">\n            <img src=\"https://images.unsplash.com/photo-1665700301284-cd7fca3388d2?auto=format&w=800&q=80&fit=crop\" alt=\"Cyber Optics\" class=\"w-full h-[400px] object-cover grayscale contrast-150 group-hover:grayscale-0 transition-all duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"53\">\n            <div class=\"vhs-overlay\" data-kid=\"54\"></div>\n          </div>\n        </div>\n        <div class=\"w-12 h-12 bg-[var(--midnight)] border-4 border-[var(--magenta)] shadow-[0_0_15px_var(--magenta)] rounded-full z-10 relative order-1 md:order-2 mb-8 md:mb-0\" data-kid=\"55\">\n          <div class=\"absolute inset-2 bg-[var(--cyan)] rounded-full animate-ping\" data-kid=\"56\"></div>\n        </div>\n        <div class=\"w-full md:w-[45%] text-left pl-0 md:pl-16 order-2 md:order-3 feature-text-right\" data-kid=\"57\">\n          <h3 class=\"text-5xl font-righteous text-[var(--cyan)] mb-4 uppercase tracking-wider\" data-kid=\"58\">HUD_INTEGRATION</h3>\n          <p class=\"text-xl text-white/70 leading-relaxed mb-6 font-vt323\" data-kid=\"59\">Direct neural-link to your digital wallet. Real-time marketplace data streamed to your optic-visor.</p>\n          <div class=\"flex gap-3 text-[var(--magenta)] font-righteous text-lg\" data-kid=\"60\">\n            <span data-kid=\"61\">[ LATENCY: 2MS ]</span>\n            <span data-kid=\"62\">[ ENCRYPTION: MAX ]</span>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </section>\n\n  \n  \n    <div class=\"absolute inset-0 grid-pattern opacity-10 pointer-events-none\" data-kid=\"63\"></div>\n    <div class=\"px-10 pt-32 pb-12 flex flex-col md:flex-row justify-between items-end gap-8 shrink-0 bg-[var(--midnight)] relative z-10\" data-kid=\"64\">\n      <div class=\"space-y-4\" data-kid=\"65\">\n        <div class=\"text-[var(--cyan)] font-righteous text-2xl tracking-[0.5em]\" data-kid=\"66\">SYSTEM_INVENTORY</div>\n        <h2 class=\"text-7xl md:text-[8rem] font-righteous text-white leading-none\" data-kid=\"67\">HARDWARE_DROP</h2>\n      </div>\n      <div class=\"text-right font-vt323 text-3xl uppercase text-[var(--magenta)]\" data-kid=\"68\">\n        <span class=\"animate-pulse\" data-kid=\"69\">●</span> LIVE_FEED_STATUS: SYNCED\n      </div>\n    </div>\n\n    \n    \n      <div id=\"vhs-track\" class=\"flex gap-20 px-20 h-full items-center\" data-kid=\"70\">\n        \n        <div class=\"vhs-item min-w-[450px] h-[650px] bg-black p-8 border-4 border-white flex flex-col group relative pixel-8bit hover:border-[var(--magenta)] transition-colors duration-300 shadow-[0_0_20px_rgba(255,255,255,0.1)]\" data-kid=\"71\">\n        <div class=\"absolute top-8 right-8 z-20 bg-[var(--magenta)] text-[var(--midnight)] font-righteous px-3 py-1 text-sm animate-pulse\" data-kid=\"72\">REC</div>\n        <div class=\"h-[75%] overflow-hidden relative border-2 border-white/20 mb-6 bg-zinc-900\" data-kid=\"73\">\n          <img src=\"https://images.pexels.com/photos/18506017/pexels-photo-18506017.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Product\" class=\"w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"