    },
    "var_384448291789": {
      "type": "variant",
      "label": "Cyberpunk Pulse",
      "parentId": "var_18a40113f029",
      "themeId": null,
      "rect": {
        "x": 6160,
        "y": -86.99983513534744,
        "w": 1440,
        "h": 800
      },
      "html": "\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n<style data-kid=\"2\">\n@import url('https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&family=Fira+Code:wght@300;400;500;600;700&display=swap');\n\n:root {\n  --ink-black: #010B13;\n  --neon-fuchsia: #FF1DCE;\n  --cyan-glow: #0FFFFF;\n  --noise: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/feTurbulence%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n}\n\nbody {\n  background-color: var(--ink-black);\n  color: white;\n  font-family: 'Fira Code', monospace;\n  overflow-x: clip;\n}\n\n.font-syncopate { font-family: 'Syncopate', sans-serif; }\n.font-fira { font-family: 'Fira Code', monospace; }\n\n/* Custom Cursor */\n#custom-cursor {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 24px;\n  height: 24px;\n  border: 1px solid var(--cyan-glow);\n  border-radius: 50%;\n  pointer-events: none;\n  z-index: 9999;\n  mix-blend-mode: difference;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n#custom-cursor::after {\n  content: '';\n  width: 4px;\n  height: 4px;\n  background: var(--neon-fuchsia);\n  box-shadow: 0 0 10px var(--neon-fuchsia);\n}\n.cursor-follower {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 8px;\n  height: 8px;\n  background: var(--cyan-glow);\n  border-radius: 50%;\n  pointer-events: none;\n  z-index: 9998;\n  mix-blend-mode: difference;\n  opacity: 0.5;\n}\n\n/* Scanlines & Noise */\n.scanlines {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n  z-index: 100;\n  background-size: 100% 2px, 3px 100%;\n  pointer-events: none;\n  opacity: 0.3;\n}\n\n/* #neon-glow */\n.neon-glow-cyan {\n  border: 1.5px solid var(--cyan-glow);\n  box-shadow: 0 0 15px rgba(15, 255, 255, 0.3), inset 0 0 5px rgba(15, 255, 255, 0.1);\n}\n.neon-glow-fuchsia {\n  border: 1.5px solid var(--neon-fuchsia);\n  box-shadow: 0 0 15px rgba(255, 29, 206, 0.3), inset 0 0 5px rgba(255, 29, 206, 0.1);\n}\n\n/* #pill-nav */\n.pill-nav {\n  position: fixed;\n  top: 1.5rem;\n  left: 50%;\n  transform: translateX(-50%);\n  background: rgba(1, 11, 19, 0.85);\n  backdrop-filter: blur(16px);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  padding: 0.6rem 1.2rem;\n  border-radius: 9999px;\n  z-index: 1000;\n  display: flex;\n  align-items: center;\n  gap: 1.5rem;\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n}\n\n/* #asymmetric-bento */\n.bento-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  grid-template-rows: auto 1fr auto;\n  gap: 1.5rem;\n  min-height: 90vh;\n}\n.bento-cell {\n  background: rgba(255, 255, 255, 0.03);\n  overflow: hidden;\n  position: relative;\n}\n\n/* #glitch-offset */\n.glitch-hover:hover::before {\n  content: '';\n  position: absolute;\n  inset: -2px;\n  border: 2px solid var(--neon-fuchsia);\n  transform: translate(-3px, 3px);\n  z-index: 10;\n  pointer-events: none;\n}\n.glitch-hover:hover::after {\n  content: '';\n  position: absolute;\n  inset: -2px;\n  border: 2px solid var(--cyan-glow);\n  transform: translate(3px, -3px);\n  z-index: 10;\n  pointer-events: none;\n}\n\n/* #diagonal-ticker */\n.ticker-container {\n  transform: rotate(-3deg) translateY(-2rem);\n  background: var(--neon-fuchsia);\n  width: 120%;\n  margin-left: -10%;\n  padding: 1rem 0;\n  border-top: 3px solid var(--ink-black);\n  border-bottom: 3px solid var(--ink-black);\n  overflow: hidden;\n  z-index: 20;\n}\n\n/* #tilted-grid - More Chaotic */\n.tilted-grid-wrapper {\n  transform: rotate(-3deg);\n  padding: 8rem 0;\n}\n.product-card-tilted {\n  background: var(--ink-black);\n  border: 3px solid white;\n  padding: 1.5rem;\n  box-shadow: 10px 10px 0 var(--cyan-glow);\n}\n.product-card-tilted:hover {\n  box-shadow: 15px 15px 0 var(--neon-fuchsia);\n  transform: translate(-5px, -5px) scale(1.02) !important;\n}\n.card-rotate-pos { transform: rotate(3deg); }\n.card-rotate-neg { transform: rotate(-2deg); }\n.card-rotate-alt { transform: rotate(4deg); }\n\n/* Animations */\n@keyframes blink { 50% { opacity: 0; } }\n.cursor-blink { animation: blink 1s step-end infinite; }\n\n/* Fixed HUD */\n.fixed-hud {\n  position: fixed;\n  bottom: 2rem;\n  right: 2rem;\n  z-index: 1000;\n  pointer-events: none;\n  font-family: 'Syncopate', sans-serif;\n  text-align: right;\n}\n\n</style>\n\n<div id=\"custom-cursor\" data-kid=\"3\"></div>\n<div class=\"cursor-follower\" data-kid=\"4\"></div>\n<div class=\"scanlines\" data-kid=\"5\"></div>\n\n<div class=\"fixed-hud hidden lg:block\" data-kid=\"6\">\n  <div class=\"text-[var(--cyan-glow)] text-[10px] font-black tracking-[0.3em] mb-1\" data-kid=\"7\">LOC: 35.6895° N, 139.6917° E</div>\n  <div class=\"text-white/40 text-[8px] tracking-widest\" data-kid=\"8\">SYS_TIME: <span id=\"sys-time\" data-kid=\"9\">23:59:59</span></div>\n</div>\n\n\n<nav class=\"pill-nav neon-glow-cyan\" data-kid=\"10\">\n  <div class=\"flex items-center gap-3 px-2 group\" data-kid=\"11\">\n    <i class=\"ti ti-cpu text-2xl text-[var(--cyan-glow)] nav-icon-wiggle\" data-kid=\"12\"></i>\n    <span class=\"font-syncopate font-bold text-sm tracking-tighter\" data-kid=\"13\">PULSE.SYS</span>\n  </div>\n  <div class=\"h-6 w-[1px] bg-white/20\" data-kid=\"14\"></div>\n  <div class=\"hidden md:flex items-center gap-8 px-4 font-syncopate text-xs uppercase tracking-[0.2em] font-bold\" data-kid=\"15\">\n    <a href=\"#\" class=\"hover:text-[var(--neon-fuchsia)] transition-colors\" data-kid=\"16\">Drops</a>\n    <a href=\"#\" class=\"hover:text-[var(--neon-fuchsia)] transition-colors\" data-kid=\"17\">Archive</a>\n    <a href=\"#\" class=\"hover:text-[var(--neon-fuchsia)] transition-colors\" data-kid=\"18\">Data</a>\n  </div>\n  <div class=\"bg-[var(--neon-fuchsia)] text-[var(--ink-black)] px-6 py-2 rounded-full font-syncopate text-xs font-black tracking-widest cursor-pointer hover:scale-105 transition-transform\" data-kid=\"19\">\n    CONNECT_V4\n  </div>\n</nav>\n\n<main class=\"relative z-10 pt-28 pb-20 px-6 max-w-screen-2xl mx-auto\" data-kid=\"20\">\n  \n  \n  <section class=\"bento-grid mb-32\" data-kid=\"21\">\n    \n    <div class=\"col-span-3 row-span-2 bento-cell neon-glow-fuchsia glitch-hover group\" data-kid=\"22\">\n      <img src=\"https://images.unsplash.com/photo-1580428180098-24b353d7e9d9?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwxfHxjeWJlcnB1bmslMjBzdHJlZXQlMjBmYXNoaW9uJTIwbW9kZWwlMjB3aXRoJTIwbmVvbiUyMGFjY2VudHN8ZW58MHx8fHwxNzgzNjU3MDY1fDA&ixlib=rb-4.1.0&q=85&auto=format&w=1200\" alt=\"Cyberpunk Model\" class=\"w-full h-full object-cover grayscale brightness-90 group-hover:grayscale-0 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n      <div class=\"absolute inset-0 bg-linear-to-tr from-[var(--ink-black)] via-transparent to-transparent opacity-80\" data-kid=\"24\"></div>\n      <div class=\"absolute bottom-16 left-16 max-w-4xl\" data-kid=\"25\">\n        <div class=\"mb-4 inline-block bg-[var(--neon-fuchsia)] text-[var(--ink-black)] px-4 py-1 font-syncopate text-xs font-black tracking-widest animate-pulse\" data-kid=\"26\">\n          // SYSTEM_INITIALIZED\n        </div>\n        <h2 class=\"font-syncopate text-6xl md:text-8xl font-black leading-none uppercase tracking-tighter scramble-target\" data-text=\"NEO_OVERDRIVE\" data-kid=\"27\">NEO_OVERDRIVE</h2>\n        <div class=\"flex flex-wrap items-center gap-6 mt-8\" data-kid=\"28\">\n          <span class=\"bg-[var(--cyan-glow)] text-[var(--ink-black)] px-4 py-1.5 font-syncopate text-xs font-black\" data-kid=\"29\">STABLE_BUILD</span>\n          <p class=\"font-fira text-base opacity-90 uppercase tracking-[0.2em] text-[var(--cyan-glow)]\" data-kid=\"30\">> SYSTEM STATUS: UNAUTHORIZED ACCESS_ALLOWED</p>\n        </div>\n      </div>\n    </div>\n    \n    \n    <div class=\"col-span-1 row-span-1 bento-cell neon-glow-cyan p-8 flex flex-col justify-between min-h-[220px]\" data-kid=\"31\">\n      <div class=\"flex justify-between items-start\" data-kid=\"32\">\n        <span class=\"text-xs font-syncopate opacity-50 uppercase tracking-widest\" data-kid=\"33\">Global_Latency</span>\n        <i class=\"ti ti-activity text-[var(--cyan-glow)] text-2xl\" data-kid=\"34\"></i>\n      </div>\n      <div data-kid=\"35\">\n        <div class=\"font-syncopate text-5xl text-[var(--cyan-glow)] mb-1\" data-kid=\"36\">12MS</div>\n        <div class=\"font-fira text-xs opacity-40 uppercase\" data-kid=\"37\">Synced with Tokyo_Edge_Node</div>\n      </div>\n    </div>\n    \n    \n    <div class=\"col-span-1 row-span-2 bento-cell neon-glow-fuchsia p-10 flex flex-col group h-full\" data-kid=\"38\">\n      <div class=\"mb-auto\" data-kid=\"39\">\n        <div class=\"font-syncopate text-xs text-[var(--neon-fuchsia)] mb-3 font-black uppercase tracking-widest\" data-kid=\"40\">// UPLINK_INITIATED</div>\n        <h3 class=\"font-syncopate text-3xl font-bold uppercase leading-tight mb-6\" data-kid=\"41\">Discovery_Core Interface</h3>\n        <p class=\"font-fira text-sm opacity-60 uppercase mb-10 leading-relaxed\" data-kid=\"42\">Accessing the decentralized retail layer. Neural sync established. Permission levels verified.</p>\n      </div>\n      <div class=\"space-y-6 mt-auto\" data-kid=\"43\">\n        <div class=\"h-[1px] bg-white/20 w-full\" data-kid=\"44\"></div>\n        <button class=\"w-full py-5 bg-[var(--neon-fuchsia)] text-[var(--ink-black)] font-syncopate text-xs font-black uppercase tracking-[0.2em] shadow-[0_0_30px_rgba(255,29,206,0.5)] hover:scale-[0.98] transition-transform cursor-pointer\" data-kid=\"45\">\n          Sync_Discovery\n        </button>\n      </div>\n    </div>\n    \n    \n    <div class=\"col-span-3 row-span-1 bento-cell neon-glow-cyan p-12 flex items-center gap-16 min-h-[180px]\" data-kid=\"46\">\n      <div class=\"flex-1\" data-kid=\"47\">\n        <div class=\"flex justify-between items-end mb-4\" data-kid=\"48\">\n          <span class=\"font-syncopate text-xs font-bold uppercase tracking-widest\" data-kid=\"49\">Resource_Allocation</span>\n          <span class=\"font-fira text-xs text-[var(--cyan-glow)]\" data-kid=\"50\">94.2%_OPTIMIZED</span>\n        </div>\n        <div class=\"h-3 w-full bg-white/5 rounded-full relative overflow-hidden\" data-kid=\"51\">\n          <div class=\"absolute inset-0 bg-linear-to-r from-[var(--cyan-glow)] to-[var(--neon-fuchsia)] w-[94.2%] animate-pulse\" data-kid=\"52\"></div>\n        </div>\n      </div>\n      <div class=\"grid grid-cols-2 gap-x-16 gap-y-4 shrink-0\" data-kid=\"53\">\n        <div data-kid=\"54\">\n          <div class=\"text-xs opacity-40 mb-2 uppercase font-fira tracking-widest\" data-kid=\"55\">TEMP</div>\n          <div class=\"font-syncopate text-3xl\" data-kid=\"56\">32°C</div>\n        </div>\n        <div data-kid=\"57\">\n          <div class=\"text-xs opacity-40 mb-2 uppercase font-fira tracking-widest\" data-kid=\"58\">LOAD</div>\n          <div class=\"font-syncopate text-3xl\" data-kid=\"59\">1.4T</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"ticker-container\" data-kid=\"60\">\n    <div class=\"ticker-track flex\" data-kid=\"61\">\n      <div class=\"ticker-content flex items-center whitespace-nowrap\" data-kid=\"62\">\n        <span class=\"font-syncopate font-black text-4xl text-[var(--ink-black)] mx-12\" data-kid=\"63\">SYSTEM_OVERRIDE // UNAUTHORIZED_ACCESS // SYSTEM_OVERRIDE // UNAUTHORIZED_ACCESS //</span>\n        <span class=\"font-syncopate font-black text-4xl text-[var(--ink-black)] mx-12\" data-kid=\"64\">SYSTEM_OVERRIDE // UNAUTHORIZED_ACCESS // SYSTEM_OVERRIDE // UNAUTHORIZED_ACCESS //</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"py-40\" data-kid=\"65\">\n    <div class=\"flex flex-col md:flex-row justify-between items-end mb-20 gap-8\" data-kid=\"66\">\n      <div class=\"max-w-xl\" data-kid=\"67\">\n        <div class=\"text-[var(--cyan-glow)] font-syncopate text-[10px] font-black mb-4 uppercase tracking-[0.3em]\" data-kid=\"68\">// HARDWARE_DROPS</div>\n        <h2 class=\"font-syncopate text-5xl md:text-7xl font-black uppercase leading-none tracking-tighter\" data-kid=\"69\">Modular_Pulse_Kicks</h2>\n      </div>\n      <div class=\"font-fira text-sm opacity-50 uppercase text-right\" data-kid=\"70\">\n        [FILTER_BY]: <span class=\"text-[var(--neon-fuchsia)]\" data-kid=\"71\">STREET_TECH</span> / ALL_MODELS\n      </div>\n    </div>\n\n    <div class=\"tilted-grid-wrapper max-w-7xl mx-auto\" data-kid=\"72\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-x-12 gap-y-32\" data-kid=\"73\">\n        \n        \n        <div class=\"product-card-tilted group fade-up-target card-rotate-pos mt-12\" data-kid=\"74\">\n          <div class=\"relative overflow-hidden aspect-square border-2 border-white mb-6 bg-white/5\" data-kid=\"75\">\n            <img src=\"https://images.unsplash.com/photo-1695480507077-c14c6103181f?auto=format&w=800&q=80\" alt=\"V0ID-WALK Sneaker\" class=\"w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:hue-rotate-15 hover-distort\" decoding=\"async\" loading=\"lazy\" data-kid=\"76\">\n            <div class=\"absolute top-4 right-4 bg-white text-[var(--ink-black)] px-3 py-1 font-syncopate text-[9px] font-black uppercase\" data-kid=\"77\">NEW_DROP</div>\n          </div>\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"78\">\n            <h3 class=\"font-syncopate text-xl font-bold upper