      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Manrope:wght@200;300;400;500;600;700;800&display=swap');\n\n  :root {\n    --color-alabaster: #F5F2ED;\n    --color-charcoal: #2A2624;\n    --color-clay: #C28B5C;\n    --color-olive: #8A9A5B;\n  }\n\n  body {\n    background-color: var(--color-alabaster);\n    color: var(--color-charcoal);\n    font-family: 'Manrope', sans-serif;\n    margin: 0;\n    overflow-x: clip; /* As per constraints for sticky, though here we use fixed/absolute wrappers */\n    position: relative;\n  }\n\n  /* #noise-grain texture */\n  body::after {\n    content: \"\";\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    opacity: 0.03;\n    pointer-events: none;\n    z-index: 9999;\n    mix-blend-mode: multiply;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  h1, h2, h3, h4, .font-serif {\n    font-family: 'Cormorant Garamond', serif;\n  }\n\n  /* Lenis Horizontal Setup */\n  .horizontal-scroll-wrapper {\n    display: flex;\n    width: fit-content;\n  }\n\n  .section {\n    width: 100vw;\n    height: 100vh;\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* Navigation Underline */\n  .nav-link {\n    position: relative;\n    padding-bottom: 6px;\n    transition: color 0.3s ease;\n  }\n  .nav-link::after {\n    content: '';\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 0;\n    height: 1px;\n    background: var(--color-clay);\n    transition: width 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n  }\n  .nav-link.active::after, .nav-link:hover::after {\n    width: 100%;\n  }\n  .nav-link.active {\n    color: var(--color-charcoal);\n  }\n\n  /* #neomorph-inset for Hero */\n  .neomorph-inset {\n    box-shadow: inset 4px 4px 10px rgba(0,0,0,0.07), inset -4px -4px 10px rgba(255,255,255,0.7);\n  }\n\n  /* #glassmorphism + #inset-highlight for Hero floating card */\n  .glass-card {\n    background: rgba(255, 255, 255, 0.45);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n    box-shadow: \n      0 4px 6px -1px rgba(0, 0, 0, 0.05), \n      0 10px 15px -3px rgba(0, 0, 0, 0.05),\n      0 20px 40px -10px rgba(0, 0, 0, 0.08),\n      inset 0 1px 0 rgba(255, 255, 255, 0.85);\n  }\n\n  /* #hairline + #hover-deepen for Categories */\n  .arc-card {\n    border: 1px solid rgba(42, 38, 36, 0.1);\n    box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n    /* No CSS transitions here to avoid GSAP conflict */\n  }\n  .arc-card:hover {\n    box-shadow: 0 15px 45px rgba(0,0,0,0.12);\n  }\n\n  /* #colored-mat for product cards */\n  .colored-mat-frame {\n    background: linear-gradient(160deg, #F5F2ED, #E8E4E0);\n    padding: 14px;\n    border-radius: 24px;\n    position: relative;\n    box-shadow: \n      inset 0 0 0 1px rgba(255,255,255,0.9), \n      inset 0 0 0 2px rgba(42, 38, 36, 0.02),\n      0 4px 20px rgba(0,0,0,0.04);\n    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.6s ease;\n  }\n  .colored-mat-frame:hover {\n    box-shadow: 0 12px 40px rgba(0,0,0,0.1);\n    transform: translateY(-5px);\n  }\n\n  /* #border-reveal + #color-transition for Discovery options */\n  .discovery-option {\n    border: 1px solid rgba(42, 38, 36, 0.1);\n    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);\n    position: relative;\n    overflow: hidden;\n  }\n  .discovery-option:hover {\n    border-color: var(--color-clay);\n    box-shadow: 0 0 12px rgba(194, 139, 92, 0.15);\n  }\n  .discovery-option::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to right, rgba(194, 139, 92, 0.05), transparent);\n    transform: translateX(-100%);\n    transition: transform 0.6s ease;\n  }\n  .discovery-option:hover::before {\n    transform: translateX(0);\n  }\n\n  /* #frosted-glass for Discovery right panel */\n  .frosted-panel {\n    background: rgba(255, 255, 255, 0.3);\n    backdrop-filter: blur(15px);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  /* #top-accent for Footer */\n  .footer-accent {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, var(--color-clay), transparent);\n  }\n\n  .no-scrollbar::-webkit-scrollbar {\n    display: none;\n  }\n  .no-scrollbar {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n\n  .handwritten-sig {\n    font-family: 'Cormorant Garamond', serif;\n    font-style: italic;\n    transform: rotate(-3deg);\n  }\n\n  /* Animation Helpers */\n  .animate-float {\n    animation: float 6s ease-in-out infinite;\n  }\n  .animate-float-delayed {\n    animation: float 7s ease-in-out infinite 1s;\n  }\n  @keyframes float {\n    0%, 100% { transform: translateY(0) rotate(0); }\n    50% { transform: translateY(-20px) rotate(5deg); }\n  }\n</style>\n\n\n<div class=\"bg-[var(--color-alabaster)] min-h-screen text-[var(--color-charcoal)]\" data-kid=\"1\">\n\n  \n  <nav id=\"tabbed-header\" class=\"fixed top-0 left-0 w-full z-50 px-12 py-8 flex items-center justify-between pointer-events-none\" data-kid=\"2\">\n    <div class=\"pointer-events-auto\" data-kid=\"3\">\n      <a href=\"#\" class=\"text-3xl font-serif text-[var(--color-charcoal)] tracking-tight\" data-kid=\"4\">Kintsugi</a>\n    </div>\n    \n    <div class=\"absolute left-1/2 -translate-x-1/2 pointer-events-auto flex space-x-12\" data-kid=\"5\">\n      <a href=\"#hero\" class=\"nav-link active text-[10px] uppercase tracking-[0.2em] font-bold text-[var(--color-charcoal)]\" data-kid=\"6\">Objects</a>\n      <a href=\"#categories\" class=\"nav-link text-[10px] uppercase tracking-[0.2em] font-bold text-[var(--color-charcoal)]/40\" data-kid=\"7\">Collections</a>\n      <a href=\"#discovery\" class=\"nav-link text-[10px] uppercase tracking-[0.2em] font-bold text-[var(--color-charcoal)]/40\" data-kid=\"8\">Discovery</a>\n    </div>\n\n    <div class=\"pointer-events-auto\" data-kid=\"9\">\n      <button class=\"text-[10px] uppercase tracking-[0.2em] font-bold text-[var(--color-charcoal)]\" data-kid=\"10\">Basket (2)</button>\n    </div>\n  </nav>\n\n  \n  <div class=\"fixed inset-0 pointer-events-none z-0\" data-kid=\"11\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/gooey-molecule.svg\" class=\"absolute top-[15%] right-[8%] w-64 opacity-[0.03] animate-float\" style=\"filter: brightness(0) saturate(100%) invert(14%) sepia(5%) saturate(760%) hue-rotate(336deg) brightness(97%) contrast(93%);\" data-kid=\"12\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/solid-leaf.svg\" class=\"absolute bottom-[15%] left-[8%] w-48 opacity-[0.03] animate-float-delayed\" style=\"filter: brightness(0) saturate(100%) invert(14%) sepia(5%) saturate(760%) hue-rotate(336deg) brightness(97%) contrast(93%);\" data-kid=\"13\">\n  </div>\n\n  <main class=\"horizontal-scroll-wrapper\" data-kid=\"14\">\n    \n    \n    <section id=\"hero\" class=\"section\" data-kid=\"15\">\n      <div class=\"max-w-[1200px] w-full px-12 pt-20\" data-kid=\"16\">\n        <div id=\"rounded-inset\" class=\"relative aspect-video rounded-[40px] neomorph-inset p-8 bg-[var(--color-alabaster)]\" data-kid=\"17\">\n          <div class=\"w-full h-full rounded-[32px] overflow-hidden relative shadow-[inset_0_4px_20px_rgba(0,0,0,0.1)]\" data-kid=\"18\">\n            <video src=\"https://videos.pexels.com/video-files/12690282/12690282-uhd_2560_1440_24fps.mp4\" poster=\"https://images.pexels.com/videos/12690282/pexels-photo-12690282.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-90\" data-kid=\"19\"></video>\n            <div class=\"absolute inset-0 bg-[var(--color-charcoal)]/5 mix-blend-multiply\" data-kid=\"20\"></div>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-charcoal)]/20 to-transparent\" data-kid=\"21\"></div>\n          </div>\n          \n          <div class=\"absolute -bottom-12 left-24 z-30 max-w-3xl hero-text-trigger\" data-kid=\"22\">\n            <h1 class=\"text-[10rem] leading-[0.75] text-[var(--color-charcoal)] font-serif\" style=\"text-shadow: 0 2px 20px rgba(245, 242, 237, 1);\" data-kid=\"23\">\n              Crafted <br data-kid=\"24\"> <span class=\"pl-28 italic font-light\" data-kid=\"25\">by Time</span>\n            </h1>\n            <p class=\"mt-10 text-lg text-[var(--color-charcoal)] max-w-md ml-16 glass-card p-12 rounded-[32px] leading-relaxed\" data-kid=\"26\">\n              Slow, deliberate, and deeply human. Our ceramics carry the thumbprints of the artisans who shaped them.\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"categories\" class=\"section\" data-kid=\"27\">\n      <div class=\"flex flex-col items-center justify-center w-full\" data-kid=\"28\">\n        <div class=\"text-center mb-24\" data-kid=\"29\">\n          <span class=\"text-[var(--color-clay)] uppercase tracking-[0.2em] text-[10px] font-bold mb-4 block\" data-kid=\"30\">Curated Editions</span>\n          <h2 class=\"text-7xl text-[var(--color-charcoal)] font-serif\" data-kid=\"31\">Nature’s Palette</h2>\n        </div>\n\n        <div class=\"relative w-full max-w-6xl h-[550px] flex items-center justify-center\" data-kid=\"32\">\n          <div class=\"arc-container flex items-center justify-center\" data-kid=\"33\">\n            <div class=\"arc-card absolute w-56 h-80 rounded-[100px] overflow-hidden bg-[var(--color-alabaster)]\" data-rotate=\"-20\" data-x=\"-340\" data-y=\"50\" data-kid=\"34\">\n              <img src=\"https://images.unsplash.com/photo-1729189566211-252094749db5?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-90\" alt=\"Tableware\" data-kid=\"35\">\n              <div class=\"absolute inset-0 bg-black/5\" data-kid=\"36\"></div>\n              <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"37\"><p class=\"italic font-serif text-2xl\" data-kid=\"38\">Tableware</p></div>\n            </div>\n            <div class=\"arc-card absolute w-56 h-80 rounded-[100px] overflow-hidden bg-[var(--color-alabaster)]\" data-rotate=\"-10\" data-x=\"-170\" data-y=\"20\" data-kid=\"39\">\n              <img src=\"https://images.unsplash.com/photo-1682421938316-4b186e25174c?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-90\" alt=\"Textiles\" data-kid=\"40\">\n              <div class=\"absolute inset-0 bg-black/5\" data-kid=\"41\"></div>\n              <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"42\"><p class=\"italic font-serif text-2xl\" data-kid=\"43\">Textiles</p></div>\n            </div>\n            <div class=\"arc-card absolute w-64 h-[400px] rounded-[120px] overflow-hidden bg-[var(--color-alabaster)] z-10\" data-rotate=\"0\" data-x=\"0\" data-y=\"-30\" data-kid=\"44\">\n              <img src=\"https://images.unsplash.com/photo-1665512594386-051aad8b9f68?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-90\" alt=\"Ceramics\" data-kid=\"45\">\n              <div class=\"absolute inset-0 bg-black/5\" data-kid=\"46\"></div>\n              <div class=\"absolute bottom-14 left-0 right-0 text-center text-white\" data-kid=\"47\"><p class=\"italic font-serif text-3xl font-bold\" data-kid=\"48\">Ceramics</p></div>\n            </div>\n            <div class=\"arc-card absolute w-56 h-80 rounded-[100px] overflow-hidden bg-[var(--color-alabaster)]\" data-rotate=\"10\" data-x=\"170\" data-y=\"20\" data-kid=\"49\">\n              <img src=\"https://images.pexels.com/photos/31935727/pexels-photo-31935727.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-full object-cover opacity-90\" alt=\"Woodwork\" data-kid=\"50\">\n              <div class=\"absolute inset-0 bg-black/5\" data-kid=\"51\"></div>\n              <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"52\"><p class=\"italic font-serif text-2xl\" data-kid=\"53\">Woodwork</p></div>\n            </div>\n            <div class=\"arc-card absolute w-56 h-80 rounded-[100px] overflow-hidden bg-[var(--color-alabaster)]\" data-rotate=\"20\" data-x=\"340\" data-y=\"50\" data-kid=\"54\">\n              <img src=\"https://images.pexels.com/photos/15361090/pexels-photo-15361090.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-full object-cover opacity-90\" alt=\"Stone\" data-kid=\"55\">\n              <div class=\"absolute inset-0 bg-black/5\" data-kid=\"56\"></div>\n              <div class=\"absolute bottom-10 left-0 right-0 text-center text-white\" data-kid=\"57\"><p class=\"italic font-serif text-2xl\" data-kid=\"58\">Stone</p></div>\n            </div>\n          </div>\n          <div class=\"absolute bottom-0 w-3 h-3 rounded-full bg-[var(--color-clay)] shadow-[0_0_10px_rgba(194,139,92,0.5)]\" data-kid=\"59\"></div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"trending\" class=\"section\" data-kid=\"60\">\n      <div class=\"w-full\" data-kid=\"61\">\n        <div class=\"px-24 mb-16 flex items-end justify-between\" data-kid=\"62\">\n          <div data-kid=\"63\">\n            <span class=\"text-[var(--color-clay)] uppercase tracking-[0.2em] text-[10px] font-bold mb-4 block\" data-kid=\"64\">New Arrivals</span>\n            <h2 class=\"text-7xl text-[var(--color-charcoal)] font-serif\" data-kid=\"65\">Objects of Devotion</h2>\n          </div>\n          <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.2em] font-bold border-b border-[var(--color-charcoal)]/20 pb-2 hover:border-[var(--color-clay)] transition-colors\" data-kid=\"66\">View Collection</a>\n        </div>\n        \n        <div id=\"peek-carousel\" class=\"flex space-x-12 overflow-x-auto snap-x snap-mandatory peek-carousel-container no-scrollbar pb-20 px-[15%]\" data-kid=\"67\">\n          \n          \n          <div class=\"product-card snap-center group min-w-[400px]\" data-kid=\"68\">\n            <div class=\"product-card-inner colored-mat-frame aspect-[4/5] relative\" data-kid=\"69\">\n              <div class=\"w-full h-full overflow-hidden rounded-lg\" data-kid=\"70\">\n                <img src=\"https://images.unsplash.com/photo-1660766474256-bb3e489b412b?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 transition-all duration-1000\" alt=\"Lunar Vase\" data-kid=\"71\">\n              </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-start px-4\" data-kid=\"72\">\n              <div data-kid=\"73\">\n                <h4 class=\"text-3xl font-serif text-[var(--color-charcoal)]\" data-kid=\"74\">Lunar Vase</h4>\n                <p class=\"text-[10px] uppercase tracking-widest text-[var(--color-charcoal)]/40 mt-1\" data-kid=\"75\">Smoke Fired Clay</p>\n              </div>\n              <span class=\"text-2xl font-bold font-serif\" style=\"font-variant-numeric: tabular-nums;\" data-kid=\"76\">$185</span>\n            </div>\n          </div>\n          \n          \n          <div class=\"product-card snap-center group min-w-[400px]\" data-kid=\"77\">\n            <div class=\"product-card-inner colored-mat-frame aspect-[4/5] relative\" data-kid=\"78\">\n              <div class=\"w-full h-full overflow-hidden rounded-lg\" data-kid=\"79\">\n                <img src=\"https://images.pexels.com/photos/12268992/pexels-photo-12268992.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 transition-all duration-1000\" alt=\"Driftwood Tray\" data-kid=\"80\">\n              </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-start px-4\" data-kid=\"81\">\n              <div data-kid=\"82\">\n                <h4 class=\"text-3xl font-serif text-[var(--color-charcoal)]\" data-kid=\"83\">Driftwood Tray</h4>\n                <p class=\"text-[10px] uppercase tracking-widest text-[var(--color-charcoal)]/40 mt-1\" data-kid=\"84\">Hand-carved Oak</p>\n              </div>\n              <span class=\"text-2xl font-bold font-serif\" style=\"font-variant-numeric: tabular-nums;\" data-kid=\"85\">$140</span>\n            </div>\n          </div>\n          \n          \n          <div class=\"product-card snap-center group min-w-[400px]\" data-kid=\"86\">\n            <div class=\"product-card-inner colored-mat-frame aspect-[4/5] relative\" data-kid=\"87\">\n              <div class=\"w-full h-full overflow-hidden rounded-lg\" data-kid=\"88\">\n                <img src=\"https://images.pexels.com/photos/6739697/pexels-photo-6739697.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 transition-all duration-1000\" alt=\"Earth Bowl\" data-kid=\"89\">\n              </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-start px-4\" data-kid=\"90\">\n              <div data-kid=\"91\">\n                <h4 class=\"text-3xl font-serif text-[var(--color-charcoal)]\" data-kid=\"92\">Earth Bowl</h4>\n                <p class=\"text-[10px] uppercase tracking-widest text-[var(--color-charcoal)]/40 mt-1\" data-kid=\"93\">Raw Terracotta</p>\n              </div>\n              <span class=\"text-2xl font-bold font-serif\" style=\"font-variant-numeric: tabular-nums;\" data-kid=\"94\">$95</span>\n            </div>\n          </div>\n          \n          \n          <div class=\"product-card snap-center group min-w-[400px]\" data-kid=\"95\">\n            <div class=\"product-card-inner colored-mat-frame aspect-[4/5] relative\" data-kid=\"96\">\n              <div class=\"w-full h-full overflow-hidden rounded-lg\" data-kid=\"97\">\n                <img src=\"https://images.pexels.com/photos/37912697/pexels-photo-37912697.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 transition-all duration-1000\" alt=\"Stone Vessel\" data-kid=\"98\">\n              </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-start px-4\" data-kid=\"99\">\n              <div data-kid=\"100\">\n                <h4 class=\"text-3xl font-serif text-[var(--color-charcoal)]\" data-kid=\"101\">Stone Vessel</h4>\n                <p class=\"text-[10px] uppercase tracking-widest text-[var(--color-charcoal)]/40 mt-1\" data-kid=\"102\">Lava Stone</p>\n              </div>\n              <span class=\"text-2xl font-bold font-serif\" style=\"font-variant-numeric: tabular-nums;\" data-kid=\"103\">$210</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"discovery\" class=\"section\" data-kid=\"104\">\n      <div class=\"w-full h-full flex\" data-kid=\"105\">\n        <div class=\"w-1/2 h-full relative overflow-hidden\" data-kid=\"106\">\n          <img src=\"https://images.unsplash.com/photo-1772268485810-29dc9d231f26?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-90\" alt=\"Serene Sunlight\" data-kid=\"107\">\n          <div class=\"absolute inset-0 bg-[var(--color-clay)]/10 mix-blend-overlay\" data-kid=\"108\"></div>\n          \n          \n          <div class=\"absolute inset-20 frosted-panel rounded-[40px] p-12 flex flex-col justify-end text-[var(--color-charcoal)]\" data-kid=\"109\">\n             <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold mb-4\" data-kid=\"110\">Discovery Phase</span>\n             <h3 class=\"text-4xl font-serif leading-tight\" data-kid=\"111\">Quiet spaces lead to <br data-kid=\"112\"> clearer thoughts.</h3>\n          </div>\n        </div>\n        \n        <div class=\"w-1/2 h-full flex items-center justify-center p-24 bg-[var(--color-alabaster)]\" data-kid=\"113\">\n          <div class=\"max-w-md w-full onboarding-fade-trigger\" data-kid=\"114\">\n            <span class=\"text-[var(--color-clay)] uppercase tracking-[0.2em] text-[10px] font-bold mb-6 block\" data-kid=\"115\">01 / The Journey</span>\n            <h2 class=\"text-6xl text-[var(--color-charcoal)] font-serif leading-tight mb-12\" data-kid=\"116\">How do you wish to feel in your space today?</h2>\n            \n            <div class=\"space-y-4\" data-kid=\"117\">\n              <button class=\"w-full discovery-option p-6 rounded-full text-left group flex items-center\" data-kid=\"118\">\n                <span class=\"w-8 h-8 rounded-full border border-current flex items-center justify-center text-[10px] mr-6 italic group-hover:bg-[var(--color-clay)] group-hover:text-white transition-all\" data-kid=\"119\">a</span>\n                <span class=\"text-lg font-medium group-hover:translate-x-1 transition-transform relative z-10\" data-kid=\"120\">Quiet and Reflective</span>\n              </button>\n              <button class=\"w-full discovery-option p-6 rounded-full text-left group flex items-center\" data-kid=\"121\">\n                <span class=\"w-8 h-8 rounded-full border border-current flex items-center justify-center text-[10px] mr-6 italic group-hover:bg-[var(--color-clay)] group-hover:text-white transition-all\" data-kid=\"122\">b</span>\n                <span class=\"text-lg font-medium group-hover:translate-x-1 transition-transform relative z-10\" data-kid=\"123\">Warm and Connected</span>\n              </button>\n              <button class=\"w-full discovery-option p-6 rounded-full text-left group flex items-center\" data-kid=\"124\">\n                <span class=\"w-8 h-8 rounded-full border border-current flex items-center justify-center text-[10px] mr-6 italic group-hover:bg-[var(--color-clay)] group-hover:text-white transition-all\" data-kid=\"125\">c</span>\n                <span class=\"text-lg font-medium group-hover:translate-x-1 transition-transform relative z-10\" data-kid=\"126\">Energized by Nature</span>\n              </button>\n            </div>\n            \n            <div class=\"mt-16 flex space-x-3\" data-kid=\"127\">\n              <div class=\"w-2 h-2 rounded-full bg-[var(--color-clay)]\" data-kid=\"128\"></div>\n              <div class=\"w-2 h-2 rounded-full bg-[var(--color-charcoal)]/10\" data-kid=\"129\"></div>\n              <div class=\"w-2 h-2 rounded-full bg-[var(--color-charcoal)]/10\" data-kid=\"130\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"footer\" class=\"section\" data-kid=\"131\">\n      <div class=\"w-full flex flex-col items-center justify-center text-center p-24 relative\" data-kid=\"132\">\n        <div class=\"footer-accent\" data-kid=\"133\"></div>\n        \n        <div class=\"max-w-3xl mb-32\" data-kid=\"134\">\n          <h3 class=\"text-4xl mb-10 leading-relaxed italic font-serif text-[var(--color-charcoal)] px-12\" data-kid=\"135\">\n            \"In the Japanese philosophy of Wabi-sabi, imperfection is the core of beauty. We celebrate the crack, the smudge, and the soul.\"\n          </h3>\n          <p class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-[var(--color-charcoal)]/40\" data-kid=\"136\">A note from our founders</p>\n        </div>\n        \n        <div class=\"w-full border-t border-[var(--color-charcoal)]/10 pt-32 flex flex-col items-center\" data-kid=\"137\">\n          <div class=\"relative mb-20\" data-kid=\"138\">\n            <div class=\"absolute -top-6 left-1/2 -translate-x-1/2 w-32 h-[1px] bg-[var(--color-clay)]\" data-kid=\"139\"></div>\n            <a href=\"#\" class=\"text-6xl font-serif text-[var(--color-charcoal)] tracking-tighter\" data-kid=\"140\">Kintsugi</a>\n          </div>\n          \n          <nav class=\"flex space-x-16 mb-20\" data-kid=\"141\">\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.2em] font-bold hover:text-[var(--color-clay)] transition-colors\" data-kid=\"142\">Our Story</a>\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.2em] font-bold hover:text-[var(--color-clay)] transition-colors\" data-kid=\"143\">Sustainability</a>\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.2em] font-bold hover:text-[var(--color-clay)] transition-colors\" data-kid=\"144\">Shipping</a>\n            <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.2em] font-bold hover:text-[var(--color-clay)] transition-colors\" data-kid=\"145\">Contact</a>\n          </nav>\n          \n          <div class=\"flex space-x-8 mb-24\" data-kid=\"146\">\n            <a href=\"#\" class=\"w-12 h-12 rounded-full border border-[var(--color-charcoal)]/10 flex items-center justify-center hover:bg-[var(--color-charcoal)]/5 hover:border-[var(--color-clay)]/30 transition-all text-xl\" data-kid=\"147\"><i class=\"ph ph-instagram-logo\" data-kid=\"148\"></i></a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-full border border-[var(--color-charcoal)]/10 flex items-center justify-center hover:bg-[var(--color-charcoal)]/5 hover:border-[var(--color-clay)]/30 transition-all text-xl\" data-kid=\"149\"><i class=\"ph ph-pinterest-logo\" data-kid=\"150\"></i></a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-full border border-[var(--color-charcoal)]/10 flex items-center justify-center hover:bg-[var(--color-charcoal)]/5 hover:border-[var(--color-clay)]/30 transition-all text-xl\" data-kid=\"151\"><i class=\"ph ph-envelope-simple\" data-kid=\"152\"></i></a>\n          </div>\n          \n          <div class=\"w-full border-t border-[var(--color-charcoal)]/10 pt-16 flex justify-between items-center text-[var(--color-charcoal)]/40 text-[10px] uppercase tracking-[0.2em] font-bold\" data-kid=\"153\">\n            <span data-kid=\"154\">&copy; 2024 Kintsugi Artisanal</span>\n            <div class=\"handwritten-sig text-3xl text-[var(--color-clay)]\" data-kid=\"155\">Made with care</div>\n            <span data-kid=\"156\">Stockholm & Kyoto</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"157\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"158\"></script>\n<script type=\"module\" data-kid=\"159\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Lenis for horizontal scrolling\n  const lenis = new Lenis({\n    orientation: 'horizontal',\n    gestureOrientation: 'both',\n    smoothWheel: true,\n    wheelMultiplier: 1.1,\n  });\n\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Sync GSAP with Lenis\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Hero Text Animation\n  gsap.from(\".hero-text-trigger h1\", {\n    y: 120,\n    opacity: 0,\n    duration: 1.8,\n    ease: \"expo.out\",\n    delay: 0.5\n  });\n  gsap.from(\".hero-text-trigger p\", {\n    y: 40,\n    opacity: 0,\n    duration: 1.2,\n    ease: \"power2.out\",\n    delay: 1.4\n  });\n\n  // Horizontal Scroll Tween\n  const scrollWrapper = document.querySelector(\".horizontal-scroll-wrapper\");\n  const scrollTween = gsap.to(scrollWrapper, {\n    x: () => -(scrollWrapper.scrollWidth - window.innerWidth),\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"main\",\n      start: \"top top\",\n      end: () => \"+=\" + (scrollWrapper.scrollWidth - window.innerWidth),\n      scrub: 1,\n      pin: true,\n      invalidateOnRefresh: true,\n    }\n  });\n\n  // Arc Fan Animation (Scroll-triggered)\n  const arcCards = document.querySelectorAll('.arc-card');\n  gsap.set(arcCards, { opacity: 0, scale: 0.7, y: 100 });\n  \n  ScrollTrigger.create({\n    trigger: \"#categories\",\n    start: \"left center\",\n    containerAnimation: scrollTween,\n    onEnter: () => {\n      arcCards.forEach((card, i) => {\n        const targetRotate = card.getAttribute('data-rotate');\n        const targetX = card.getAttribute('data-x');\n        const targetY = card.getAttribute('data-y');\n        \n        gsap.to(card, {\n          opacity: 1,\n          scale: 1,\n          rotate: targetRotate,\n          x: targetX,\n          y: targetY,\n          duration: 2,\n          delay: i * 0.12,\n          ease: \"expo.out\"\n        });\n      });\n    }\n  });\n\n  // Product Cards Entrance\n  gsap.from(\".product-card\", {\n    scrollTrigger: {\n      trigger: \"#trending\",\n      containerAnimation: scrollTween,\n      start: \"left center\",\n    },\n    x: 80,\n    opacity: 0,\n    stagger: 0.15,\n    duration: 1.8,\n    ease: \"power4.out\"\n  });\n\n  // Discovery Fade In\n  gsap.from(\".onboarding-fade-trigger\", {\n    scrollTrigger: {\n      trigger: \"#discovery\",\n      containerAnimation: scrollTween,\n      start: \"left center\",\n    },\n    opacity: 0,\n    x: 60,\n    duration: 1.8,\n    ease: \"expo.out\"\n  });\n</script>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"160\">\n<script src=\"https://unpkg.com/@phosphor-icons/web\" data-kid=\"161\"></script>\n",
