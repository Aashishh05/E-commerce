class=\"flex items-center gap-8\" data-kid=\"161\">\n        <div class=\"flex gap-6\" data-kid=\"162\">\n          <a href=\"#\" class=\"text-3xl hover:text-[var(--magenta)] transition-colors\" data-kid=\"163\"><i class=\"fa-brands fa-discord\" data-kid=\"164\"></i></a>\n          <a href=\"#\" class=\"text-3xl hover:text-[var(--cyan)] transition-colors\" data-kid=\"165\"><i class=\"fa-brands fa-twitter\" data-kid=\"166\"></i></a>\n        </div>\n        <button class=\"px-8 py-3 bg-[var(--cyan)] text-[var(--midnight)] font-righteous text-xl pixel-8bit hover:brightness-110 transition-all shadow-[0_0_15px_rgba(0,255,255,0.3)]\" data-kid=\"167\">CONNECT</button>\n      </div>\n    </footer>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"168\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"169\"></script>\n<script data-kid=\"170\">gsap.registerPlugin(ScrollTrigger);</script>\n<script type=\"module\" data-kid=\"171\">\n  import Lenis from \"https://esm.sh/lenis@1\";\n\n  // Init Lenis\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    orientation: 'vertical',\n    gestureOrientation: 'both',\n    smoothWheel: true,\n  });\n\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Custom Cursor\n  const cursor = document.getElementById('arcade-cursor');\n  document.addEventListener('mousemove', (e) => {\n    gsap.to(cursor, {\n      x: e.clientX - 10,\n      y: e.clientY - 10,\n      duration: 0.2,\n      ease: \"power2.out\"\n    });\n  });\n\n  // Hero Card Entrance - Anime Spring Wobble style\n  gsap.from(\".hero-island\", {\n    y: 100,\n    opacity: 0,\n    duration: 1.5,\n    ease: \"elastic.out(1, 0.5)\",\n    delay: 0.5\n  });\n\n  // Ambient Gradient Drift\n  gsap.to(\".aurora-bg\", {\n    scale: 1.2,\n    x: \"10%\",\n    y: \"5%\",\n    duration: 10,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n\n  // Feature Ladder GSAP Parallax (Proper replacement for Locomotive)\n  gsap.utils.toArray('.feature-row').forEach((row, i) => {\n    const textSide = row.querySelector('.feature-text-left, .feature-text-right');\n    const imageSide = row.querySelector('.feature-image-right, .feature-image-left');\n    \n    gsap.from(textSide, {\n      scrollTrigger: {\n        trigger: row,\n        start: \"top 90%\",\n      },\n      x: i % 2 === 0 ? -50 : 50,\n      opacity: 0,\n      duration: 1.2,\n      ease: \"power3.out\"\n    });\n    \n    gsap.from(imageSide, {\n      scrollTrigger: {\n        trigger: row,\n        start: \"top 80%\",\n      },\n      x: i % 2 === 0 ? 50 : -50,\n      opacity: 0,\n      duration: 1.2,\n      delay: 0.2,\n      ease: \"power3.out\"\n    });\n  });\n\n  // GSAP Pinning Horizontal Scroll for Products\n  const track = document.getElementById('vhs-track');\n  const scrollWidth = track.scrollWidth - window.innerWidth;\n\n  gsap.to(track, {\n    x: () => -scrollWidth,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"#products\",\n      start: \"top top\",\n      end: () => \"+=\" + scrollWidth,\n      scrub: 1,\n      pin: true,\n      anticipatePin: 1,\n    }\n  });\n\n  // Footer Breathe Animation\n  gsap.to(\".pulse-breathe\", {\n    scale: 1.02,\n    duration: 2,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n\n  // Scramble text effect for title\n  const scrambleElements = document.querySelectorAll('h1, h2');\n  scrambleElements.forEach(el => {\n    const originalText = el.innerText;\n    el.addEventListener('mouseenter', () => {\n      let iteration = 0;\n      const interval = setInterval(() => {\n        el.innerText = el.innerText.split(\"\")\n          .map((char, index) => {\n            if (index < iteration) return originalText[index];\n            return String.fromCharCode(65 + Math.floor(Math.random() * 26));\n          }).join(\"\");\n        if (iteration >= originalText.length) clearInterval(interval);\n        iteration += 1 / 3;\n      }, 30);\n    });\n  });\n</script>\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"172\">\n</main>",
